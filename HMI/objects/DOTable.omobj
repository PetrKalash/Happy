	<object access-modifier="private" name="CountChannels" display-name="Количество каналов" uuid="7ed954e3-79a3-412b-bdbd-6e4c98500d68" base-type="notifying_int4" base-type-id="5ccca629-a45d-46c8-a56c-83ecde8126f7" ver="5" description="" cardinal="1"/>
