	<object access-modifier="private" name="LayoutMargins" display-name="LayoutMargins" uuid="96e0ce83-2576-4f3d-9863-b8affe0cd5dd" base-type="LayoutMargins" base-type-id="d86ce751-1ea7-42c6-8d4b-10c651a2727d" ver="5" description="" cardinal="1">
