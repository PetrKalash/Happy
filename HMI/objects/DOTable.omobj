	<object access-modifier="private" name="Timer" display-name="Timer" uuid="cbd46591-0d16-4232-89ca-4278342b6725" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
		<designed target="Period" value="200" ver="5"/>
		<designed target="Active" value="true" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
			<body kind="javascript">
				<![CDATA[for (let i = 0; i < Body.Column.Length; i++) {
	for (let j = 0; j < Body.Column[i].DOData.Length; j++) {
		Body.Column[i].DOData[j].Channel.Text_1.Text = String(Body.Column[i].DOData[j].NumberChannel);
		Body.Column[i].DOData[j].CurrentValue.Settings.DOSet.Signal.ValuePath = Body.Column[i].DOData[j].PathSignal;
		if (i == 0) {
			Body.Column[i].DOData[j].LayoutMargins_1.Right = 1;
		} else {
			Body.Column[i].DOData[j].LayoutMargins_1.Right = 0;
		}
	}
}
// сколько каналов в первой колонке
const firstMax  = Math.ceil(CountChannels / 2);
// сколько каналов во второй (остаток)
const secondMax = CountChannels - firstMax;

// колонка 0 скрывает всё с индекса firstMax
for (let j = firstMax; j < Body.Column[0].DOData.Length; j++) {
  Body.Column[0].DOData[j].Visible = false;
}

// колонка 1 скрывает всё с индекса secondMax
for (let j = secondMax; j < Body.Column[1].DOData.Length; j++) {
  Body.Column[1].DOData[j].Visible = false;
}
me.Active = false;]]>
			</body>
		</do-on>
	</object>
	<object access-modifier="private" name="Timer2" display-name="Timer2" uuid="9c25e90a-8fee-4f25-b2f4-a170020ecec4" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
		<designed target="Period" value="300" ver="5"/>
		<designed target="Active" value="true" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
			<body kind="javascript">
				<![CDATA[for (let i = 0; i < Body.Column.Length; i++) {
	for (let j = 0; j < Body.Column[i].DOData.Length; j++) {
		if (Body.Column[i].DOData[j].UDKS.Value == true) {
			if (unit.Security.Access_Engineer.Value && !unit.Security.Access_Operator.Value) {
				Body.Column[i].DOData[j].CurrentValue.Settings.DOSet.EnableEngineer = true;
			} else if (!unit.Security.Access_Engineer.Value && (unit.Security.Access_Operator.Value || (!unit.Security.Access_Operator.Value && !unit.Security.Access_Engineer.Value))) {
				Body.Column[i].DOData[j].CurrentValue.Settings.DOSet.EnableEngineer = false;
				Body.Column[i].DOData[j].CurrentValue.Settings.DOSet.Visible = false;
			}
			if (Body.Column[i].DOData[j].PathUDKS.Value == true && ((!unit.Security.Access_Engineer.Value && unit.Security.Access_Operator.Value) || (!unit.Security.Access_Operator.Value && !unit.Security.Access_Engineer.Value))) {
				Body.Column[i].DOData[j].CurrentValue.Settings.DOUDKS.Visible = true;
			} else {
				Body.Column[i].DOData[j].CurrentValue.Settings.DOUDKS.Visible = false;
			}
			
			if (Title.Channel.SbrosUDKS.DO_Signal.Out.Value) {
				Body.Column[i].DOData[j].CurrentValue.Settings.DOSet.DO_Signal.In.Value = false;
				Body.Column[i].DOData[j].CurrentValue.Settings.DOSet.DO_Signal.Out.Value = false;
			}			
			
		}
		Body.Column[i].DOData[j].Parameter.Text_1.Text = Body.Column[i].DOData[j].NameSignal;
	}
}

// В будущем, пожалуйста, создайте элементы AP, чтобы доставать из астры параметры Security. А то я не могу уже писать эти unit.Security]]>
			</body>
		</do-on>
	</object>
	<object access-modifier="private" name="Timer3" display-name="Timer3" uuid="89ef313c-a94f-40fb-ac9e-bb50cbb4eeed" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
		<designed target="Period" value="1000" ver="5"/>
		<designed target="Active" value="true" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
			<body kind="javascript">
				<![CDATA[for (let i = 0; i < Body.Column.Length; i++) {
	for (let j = 0; j < Body.Column[i].DOData.Length; j++) {
		if (Body.Column[i].DOData[j].IncorrectValue.Value) {
		   Body.Column[i].DOData[j].Parameter.PenColor = "0xffaa00ff";
		   Body.Column[i].DOData[j].Parameter.PenWidth = 2;
		}
		
		let cell = Body.Column[i].DOData[j].NameSignal.Value;
		let name = cell || '';
     
     if (Body.Column[i].DOData[j].CurrentValue.Settings.DOSet.DO_Signal.Out.Path && 
     Body.Column[i].DOData[j].CurrentValue.Settings.DOSet.Signal.ValuePath == "") {
	     if (!Body.Column[i].DOData[j].PathUDKS.Advised) {
	     	Body.Column[i].DOData[j].Parameter.PenColor = "0xffff0000";
	     	if (!unit.Source.Connection) {
	     		Body.Column[i].DOData[j].Parameter.PenWidth = 1;
	     	} else {
					Body.Column[i].DOData[j].Parameter.PenWidth = 2;
				}
	     }
	  } 
		else if (!Body.Column[i].DOData[j].CurrentValue.Settings.DOSet.DO_Signal.Out.Advised
		&& !Body.Column[i].DOData[j].IncorrectValue.Value
		&& !/^резерв$/i.test(name.trim())) {
			Body.Column[i].DOData[j].Parameter.PenColor = "0xffff0000";
			Body.Column[i].DOData[j].Parameter.PenWidth = 2;
		}
	}
}
me.Active = false;]]>
			</body>
		</do-on>
	</object>
</type>

