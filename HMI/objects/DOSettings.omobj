	<object access-modifier="private" name="AlarmMessage" display-name="AlarmMessage" uuid="a221b464-19e5-449b-8d2f-304b71be8dd4" base-type="Action" base-type-id="a9ee9770-1c4a-44c9-b815-157d9fc2ab95" ver="5" description="" cardinal="1">
		<designed target="Enabled" value="true" ver="5"/>
		<designed target="InvokeTrigger" value="false" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Invoked" form-action="open-dialog" form-by-id="false">
			<object access-modifier="private" uuid="ee72d786-a621-4399-9c59-4fe5138c6a39" base-type="MessageDialog_1" base-type-id="e57be645-5922-4aa1-be96-4629255ec5dc" ver="5">
				<init target="Message" ver="5" ref="here.Alarm_message"/>
				<init target="Icon" ver="5" value="2"/>
			</object>
		</do-on>
	</object>
	<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="MouseClick">
		<body kind="om">
			<![CDATA[DebugTool_1.Log(Alarm_message.Value);

if( String.Length(Alarm_message) != 0 || (DopException && String.Length(DopExceptionText) != 0) )
{
	AlarmMessage.Invoke();
}
else
{
	if (!DopAction.Enabled){
		here.AcceptDialog.Invoke();
	} else {
		DopAction.Invoke();
	}	
}]]>
		</body>
	</do-on>
	<object access-modifier="private" name="DebugTool_1" display-name="DebugTool_1" uuid="48e8d087-a7ac-4bb7-8e47-766469bb97df" base-type="DebugTool" base-type-id="43946044-139a-43f4-a7b8-19a6074ffc56" ver="5" description="" cardinal="1"/>
