	<init target="CommandValue" ver="5" value="true"/>
	<object access-modifier="private" name="AcceptDialog" display-name="AcceptDialog" uuid="1f77241f-7774-4c7f-be85-551bae88a88b" base-type="Action" base-type-id="a9ee9770-1c4a-44c9-b815-157d9fc2ab95" ver="5" description="" cardinal="1">
		<designed target="Enabled" value="true" ver="5"/>
		<designed target="InvokeTrigger" value="false" ver="5"/>
		<do-on access-modifier="private" name="Handler_2" display-name="Handler_2" ver="5" event="Invoked" form-action="open-dialog" form-by-id="false">
			<object access-modifier="private" uuid="f6f0638d-5322-4293-a509-a175be7b94b5" base-type="MessageDialog_1" base-type-id="e57be645-5922-4aa1-be96-4629255ec5dc" ver="5">
				<init target="WindowCaption" ver="5" ref="here.WindowName"/>
				<init target="Icon" ver="5" value="1"/>
				<init target="Buttons" ver="5" value="2"/>
				<init target="YesAction" ver="5" ref="ActionYes"/>
				<init target="Message" ver="5" ref="here.CommandText"/>
			</object>
		</do-on>
		<object access-modifier="private" name="ActionYes" display-name="ActionYes" uuid="ccf684a7-3c6b-44fc-a52f-fca05643fb34" base-type="Action" base-type-id="a9ee9770-1c4a-44c9-b815-157d9fc2ab95" ver="5" description="" cardinal="1">
			<designed target="Enabled" value="true" ver="5"/>
			<designed target="InvokeTrigger" value="false" ver="5"/>
			<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Invoked">
				<body kind="om">
					<![CDATA[here.Signal.In = here.CommandValue;]]>
				</body>
			</do-on>
		</object>
	</object>
	<init target="WindowName" ver="5" value="Подтверждение команды"/>
	<init target="WindowName_1" ver="5" value="Внимание"/>
	<init target="Alarm_message" ver="5" value="Действие запрещено по неопределенным причинам"/>
	<do-trace access-modifier="private" target="Alarm_message" ver="5">
		<conditional-expr>
			<condition>
				<![CDATA[!unit.Source.Connection]]>
			</condition>
			<expr>
				<![CDATA["Действие недоступно по причине отсутствия связи с контроллерами"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[DopException]]>
			</condition>
			<expr>
				<![CDATA[DopExceptionText]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[!unit.Security.Access_Operator && !unit.Security.Access_Engineer && EnableAuth]]>
			</condition>
			<expr>
				<![CDATA["Данное действие недоступно для неавторизованного пользователя"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[!(unit.ModeWork.Access || (unit.ModeWork.IsPU && unit.ModeWork.ModeWork == 4)) && EnableAccess && !EnableAuto]]>
			</condition>
			<expr>
				<![CDATA["Действие недоступно в текущем режиме работы"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[!unit.Security.Access_Engineer && EnableEngineer]]>
			</condition>
			<expr>
				<![CDATA["Данное действие доступно только пользователям с правами Инженера и выше"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[(!unit.Security.Access_Operator || !unit.Security.Access_Engineer) && EnableAdmin]]>
			</condition>
			<expr>
				<![CDATA["Данное действие доступно только пользователям с правами администратора"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[!(unit.ModeWork.Access || (unit.ModeWork.IsPU && unit.ModeWork.ModeWork == 4) || unit.ModeWork.ModeWork == 6) && !EnableAccess && EnableAuto]]>
			</condition>
			<expr>
				<![CDATA["Действие недоступно в текущем режиме работы"]]>
			</expr>
		</conditional-expr>
		<default-expr>
			<expr>
				<![CDATA[""]]>
			</expr>
		</default-expr>
	</do-trace>
	<object access-modifier="private" name="EnableAuth" display-name="Только авторизованным" uuid="9d62e465-bde0-49aa-8b08-b984444f07d3" base-type="notifying_bool" base-type-id="f8797810-1baa-4a1f-af36-cf839bf252e8" ver="5" description="" cardinal="1"/>
	<object access-modifier="private" name="EnableEngineer" display-name="Только инженер" uuid="a59a1f39-c03a-40fe-9379-942307c4e002" base-type="notifying_bool" base-type-id="f8797810-1baa-4a1f-af36-cf839bf252e8" ver="5" description="" cardinal="1"/>
	<object access-modifier="private" name="EnableAdmin" display-name="Только админ" uuid="06ade250-f146-4461-85d3-ac56e3e968a1" base-type="notifying_bool" base-type-id="f8797810-1baa-4a1f-af36-cf839bf252e8" ver="5" description="" cardinal="1"/>
	<object access-modifier="private" name="EnableAccess" display-name="Контроль режима работы" uuid="8b2b36a8-cf68-437b-82ee-f38837643afb" base-type="notifying_bool" base-type-id="f8797810-1baa-4a1f-af36-cf839bf252e8" ver="5" description="" cardinal="1"/>
	<init target="EnableAuth" ver="5" value="true"/>
	<init target="EnableAccess" ver="5" value="true"/>
	<designed target="Width" value="150" ver="5"/>
	<designed target="Height" value="30" ver="5"/>
