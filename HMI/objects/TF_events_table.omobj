					<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
						<body kind="om">
							<![CDATA[if (!Success && !Error){
parent.Text = String.ToString("%.1f",TypeConvert.ToFloat(100 / TypeConvert.ToFloat(Row_count) *  Variant.ToFloat(Row_read.Out,0)) ) + "%
" + Row_read.Out.ValueAsString + "/" + String.ToString(Row_count);
} else if (Error) {
	me.Active=false;
} else if (Success) {
	parent.Text = "100%
	" + String.ToString(ProgressBar.MaxLimit) + "/" + String.ToString(ProgressBar.MaxLimit);
}
]]>
						</body>
					</do-on>
				</object>
			</object>
			<object access-modifier="private" name="Timer" display-name="Timer" uuid="6d8bb79d-d098-4bfd-a899-2960bc7f4a32" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
				<designed target="Period" value="1000" ver="5"/>
				<designed target="Active" value="true" ver="5"/>
				<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
					<body kind="om">
						<![CDATA[
	// в данном коде вычисляется максимальное значение индикатора прогресса. его необходимо вычислять из-за того, что период, за который запрашивается																		 архив, всегда разный
	// сначала собираем начальную дату архива
	beginDate: uint8 = Begin;
	
	//затем собираем конечную дату архива
	endDate: uint8 = End;
	
	// создаем даты, равные одному часу и одному дню
	oneDay: uint8 = DateTime.Create(1601,1,2,0,0,0);
	oneHour: uint8 = DateTime.Create(1601,1,1,1,0,0);
	
	// в зависимости от типа архива нам нужно сначала отнять от большей даты меньшую, а потом
	// 1 - разделить полученную дату на 1 час для почасовых архивов, чтобы получить количество часов в этом периоде, а значит колличество строк в таблице
	// 2 - разделить полученную дату на 1 день для посуточных архивов
	if (Archive_type_SP == 1) {
			parent.MaxLimit = TypeConvert.ToInt4((endDate - beginDate) / oneHour) + 1;
		} else if (Archive_type_SP == 2) {
			parent.MaxLimit = TypeConvert.ToInt4((endDate - beginDate) / oneDay) + 1;
		}

me.Active=false;]]>
					</body>
				</do-on>
			</object>
