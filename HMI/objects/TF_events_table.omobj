					<init target="Path" ver="5" value="step"/>
					<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnValueChanged">
						<body kind="om">
							<![CDATA[if (Archive_type_SP == 1){
	if (value == 1)			parent.Text = "Запрос архива событий за заданный интервал...";
	else if (value == 2)	parent.Text = "Чтение списка событий..."; 
	else if (value == 3) 	parent.Text = "Запрос информации об определенном событии...";
	else if (value == 4)	parent.Text = "Чтение информации о пакете событий...";
	else if (value == 5)	parent.Text = "Занесение пакета событий в таблицу...";
	
} else if (Archive_type_SP == 2){
	if 		(value == 1)	parent.Text = "Запрос архива вмешательств за заданный интервал...";
	else if 	(value == 2)	parent.Text = "Чтение списка вмешательств..."; 
	else if 	(value == 3) 	parent.Text = "Запрос информации об определенном вмешательстве...";
	else if 	(value == 4)	parent.Text = "Чтение информации о пакете вмешательств...";
	else if 	(value == 5)	parent.Text = "Занесение пакета вмешастельств в таблицу...";
}
]]>
						</body>
					</do-on>
				</object>
			</object>
			<object access-modifier="private" name="Info_text" display-name="Info_text" uuid="b76ca2d9-1edf-4fae-bad7-e2d7f17a618c" base-type="Text" base-type-id="21d59f8d-2ca4-4592-92ca-b4dc48992a0f" ver="5" description="" cardinal="1">
