				<designed target="Text" value="Прибор: UFG.F; зав. номер 'Вычисляется...'; Время прибора: 'Вычисляется...'" ver="5"/>
				<designed target="Font" value="Golos Text,12,-1,5,50,0,0,0,0,0,Обычный" ver="5"/>
				<designed target="FontColor" value="0xffffffff" ver="5"/>
				<designed target="TextAlignment" value="129" ver="5"/>
				<object access-modifier="private" name="Timer_1" display-name="Timer_1" uuid="d7094d87-2a92-4038-89a1-5876d8337d9b" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
					<designed target="Period" value="1000" ver="5"/>
					<designed target="Active" value="true" ver="5"/>
					<do-on access-modifier="private" name="Handler_3" display-name="Handler_3" ver="5" event="OnTimer">
						<body kind="om">
							<![CDATA[tfDate: uint8 = DateTime.Parse(Date_time, "%d.%m.%Y %H:%M:%S");
// создаем дату из ввремени панели

if (String.Equals(Date_diff, "")){
// вычислаем разницу между датой на турбофлоу и на панели
Date_diff = DateTime.ToString(Math.Max(DateTime.Now(), tfDate )- Math.Min(tfDate, DateTime.Now()), "%T");
}


// записываем в строку над таблицами значения зав. номера, разницу хода часов и время на турбофлоу
Body.TitleBody.Info_text.Text = "Прибор: UFG.F; Заводской номер: " + String.ToString(Serial) + "; Время прибора: " + Date_time + "; Разница во времени: " + Date_diff + ";";

]]>
						</body>
					</do-on>
					<do-trace access-modifier="private" target="Active" ver="5">
						<body>
							<![CDATA[!Success && !Error]]>
						</body>
					</do-trace>
				</object>
