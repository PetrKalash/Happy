			<do access-modifier="private" name="AddNewRow" display-name="AddNewRow" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
				<body kind="om">
					<![CDATA[rowCount: int4 = TableModel.GetRowCount();
TableModel.AddRow();

	TableModel.SetCellData(rowCount, 0, String.ToString(rowCount+1));
	TableModel.SetCellData(rowCount, 1, Source_Archive.D);
	TableModel.SetCellData(rowCount, 2, Source_Archive.MSG);

	TableModel.SetCellData(rowCount, 3, Source_Archive.Old_data);
	TableModel.SetCellData(rowCount, 4, Source_Archive.New_data);

	TableModel.SetCellData(rowCount, 14, rowCount%2);		
	
Row_read.In = TypeConvert.ToInt2(Variant.ToInt2(Row_read.In, 0) + 1);

]]>
