parent.TableModel.AddColumn(Column_D.Id, Column_D.Title, Column_D.Description, "", "string", false, true);
parent.TableModel.AddColumn(Column_MSG.Id, Column_MSG.Title, Column_MSG.Description, "", "string", false, true);

	parent.TableModel.AddColumn(Column_New_data.Id, Column_New_data.Title, Column_New_data.Description, "", "string", false, true);
	parent.TableModel.AddColumn(Column_Old_data.Id, Column_Old_data.Title, Column_Old_data.Description, "", "string", false, true);

parent.TableModel.AddColumn(Column_Decor.Id, Column_Decor.Title, Column_Decor.Description, "", "uint2", false, true);
TableDecorator_1.JsonDecorator = TableDecorator_1.JsonDecorator;]]>
