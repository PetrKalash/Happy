			<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Invoked">
				<body kind="om">
					<![CDATA[	rowCount: int4 = Body.Archive_table.TableModel.GetRowCount();
	if (rowCount == 0) {
		Body.Archive_table.AddNewRow();

		
	} else if (!String.Equals(Variant.ToString(Body.Archive_table.TableModel.GetCellData(rowCount-1, 0), ""), Source_Archive.I)) {
		Body.Archive_table.AddNewRow();
	
	} ]]>
				</body>
			</do-on>
