				<![CDATA[if (value) {
	Body.TitleBody.Action_text.Text = "Архив успешно сформирован. Время формирования: " + DateTime.ToString(DateTime.Now());
	Body.TitleBody.Action_text.FontColor = 0xff00ff00;
	Body.TitleBody.Action_text.Image.Timer.Active = false;
	Body.TitleBody.Action_text.Image.Rotation = 0;
	Body.TitleBody.Action_text.Image.ImageFile = "check.png"; 

}]]>
			</body>
		</do-on>
