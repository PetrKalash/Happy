				<object access-modifier="private" name="Timer_1" display-name="Timer_1" uuid="904ac710-f334-48af-b6d5-5d203ea229ee" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
					<designed target="Period" value="1000" ver="5"/>
