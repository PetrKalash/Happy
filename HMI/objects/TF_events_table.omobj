	<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Opened">
		<body kind="om">
			<![CDATA[Start=true;
Row_read.In=0;

if (GetLogs) {
	OpenLogs.Invoke();
}
if (Archive_type_SP == 1) {
	here.Head.Text_1.Text = "Архив событий";
} else {
	here.Head.Text_1.Text = "Архив вмешательств";
}]]>
		</body>
	</do-on>
