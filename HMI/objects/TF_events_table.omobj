		<object access-modifier="private" name="AddRow" display-name="AddRow" uuid="47b6ac90-7182-4bd7-9be1-557b09523c70" base-type="Action" base-type-id="a9ee9770-1c4a-44c9-b815-157d9fc2ab95" ver="5" description="" cardinal="1">
