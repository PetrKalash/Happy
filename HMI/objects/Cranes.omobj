		<object access-modifier="private" name="line_TS_O" display-name="line_TS_O" uuid="1ce8e3a8-50ac-4776-bc8a-4225e994fb2e" base-type="ApItemBool" base-type-id="e3f11724-0f76-4497-8d01-38fbb82fb844" ver="5" description="" cardinal="1">
