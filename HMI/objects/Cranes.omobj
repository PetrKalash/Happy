		<object access-modifier="private" name="Status_line_TU_C" display-name="Status_line_TU_C" uuid="5c94b671-cd4a-4edf-a547-0070786be1ea" base-type="ApItemUInt2" base-type-id="d6557328-aca6-4831-a14e-08aed3c64a82" ver="5" description="" cardinal="1">
