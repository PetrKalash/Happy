<object access-modifier="private" name="Cranes" display-name="Cranes" uuid="1d3ae9cb-6656-4e6d-8897-9d18f8631a32" base-type="" base-type-id="00000000-0000-0000-0000-000000000000" ver="5" description="" cardinal="1">
	<do access-modifier="private" name="CheckCrane" display-name="CheckCrane" ver="5" type="string" type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d">
		<body kind="om">
			<![CDATA[warningMessage: string = "";


	if (TS_O) {
		warningMessage += "- ошибка ТС открытого положения";
	} 
	if (TS_C) {
		warningMessage += " - ошибка ТС закрытого положения";
	} 
	if (TU_O > 0) {
		warningMessage += " - ошибка ТУ команды открытия";	
	} 
	if (TU_C > 0) {
		warningMessage += " - ошибка ТУ команды закрытия";	
	}
		

if (needed != 0){
	neededText: string = "закрыт"; 
	if (needed==2) neededText = "открыт";

	if (craneStatus == 3) warningMessage += " - ошибка положения крана";
	else if (craneStatus == 0) warningMessage += " - промежуточное положение крана";
	else if (needed == 4) warningMessage = warningMessage;
	else if (craneStatus != needed) warningMessage += " - кран " + neededText;

}

if (String.Length(String.Trim(warningMessage)) > 0) warningMessage = name + warningMessage;
else warningMessage = "";

return warningMessage;
]]>
		</body>
		<param access-modifier="private" name="craneStatus" display-name="" uuid="ab02b34e-e067-43a9-a68f-1c8bb3a074ef" base-type="uint2" base-type-id="ae923ad8-8b75-4813-8121-36efe3cc8c12" ver="5"/>
		<param access-modifier="private" name="name" display-name="" uuid="1f9c87a4-3030-447c-880c-9813f12b87e9" base-type="string" base-type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d" ver="5"/>
		<param access-modifier="private" name="needed" display-name="" uuid="f87e60f2-8459-469e-aa13-4183766adc90" base-type="uint2" base-type-id="ae923ad8-8b75-4813-8121-36efe3cc8c12" ver="5"/>
		<param access-modifier="private" name="TS_O" display-name="" uuid="db1af01e-d7dc-4ba6-bdc7-a3063ec0622c" base-type="bool" base-type-id="7c9fe1ab-1ee2-42d8-939f-94ce3e89fca8" ver="5"/>
		<param access-modifier="private" name="TS_C" display-name="" uuid="e4f12d42-8163-4db5-9cbe-8cc5711cf570" base-type="bool" base-type-id="7c9fe1ab-1ee2-42d8-939f-94ce3e89fca8" ver="5"/>
		<param access-modifier="private" name="TU_O" display-name="" uuid="db5752cb-f3ca-4204-82d1-2295b6c39aea" base-type="uint2" base-type-id="ae923ad8-8b75-4813-8121-36efe3cc8c12" ver="5"/>
		<param access-modifier="private" name="TU_C" display-name="" uuid="50bd02e6-cbff-4f6d-a09e-ed1a5299089d" base-type="uint2" base-type-id="ae923ad8-8b75-4813-8121-36efe3cc8c12" ver="5"/>
	</do>
