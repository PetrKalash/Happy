	<object access-modifier="private" name="CustomTable" display-name="CustomTable" uuid="03df317f-1376-4a4f-a7f8-fa697fe4d8f9" base-type="Table" base-type-id="c65ff4dc-f22b-47d3-9333-72c4e4e5f662" base-const="true" base-ref="true" ver="5" description=""/>
	<do access-modifier="private" name="OnMove" display-name="OnMove" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
		<body kind="javascript">
			<![CDATA[if (MouseDown) {

	if (MouseInY < MouseY - 25) {
		CurrentCell = CurrentCell - 1;
		
		if (CurrentCell <0) CurrentCell = 0;
		
		MouseInY = MouseY;
		CustomTable.ScrollTo(CurrentCell,1,3);
	}
	
	if (MouseInY > MouseY + 25) {
		CurrentCell = CurrentCell + 1;
		
		if (AlternativMaxSbros == false) {
			if (CurrentCell > CustomTable.TableModel.GetRowCount()) {
					CurrentCell = CustomTable.TableModel.GetRowCount()-1;
				}
		} else {
			AltSbros.Invoke();
		}
		
		
		MouseInY = MouseY;
		CustomTable.ScrollTo(CurrentCell,1,3);
	}
}
]]>
		</body>
	</do>
	<do access-modifier="private" name="OnPress" display-name="OnPress" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
		<body kind="javascript">
			<![CDATA[MouseDown=true;
MouseInX=here.MouseX;
MouseInY=here.MouseY;]]>
		</body>
	</do>
	<do access-modifier="private" name="OnRelease" display-name="OnRelease" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
		<body kind="javascript">
			<![CDATA[MouseDown=false;]]>
		</body>
	</do>
	<do access-modifier="private" name="OnLeave" display-name="OnLeave" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
		<body kind="javascript">
			<![CDATA[MouseDown=false;]]>
		</body>
	</do>
	<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="MouseMove">
		<body kind="javascript">
			<![CDATA[OnMove();]]>
		</body>
	</do-on>
	<do-on access-modifier="private" name="Handler_2" display-name="Handler_2" ver="5" event="MousePress">
