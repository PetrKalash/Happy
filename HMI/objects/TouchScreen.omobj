	<init target="AlternativMaxSbros" ver="5" value="false"/>
	<object access-modifier="private" name="isSbrosCurrentCell" display-name="Обнулить счётчик " uuid="da13db10-ce12-4ae7-94da-2a33402d9a7d" base-type="notifying_bool" base-type-id="f8797810-1baa-4a1f-af36-cf839bf252e8" ver="5" description="" cardinal="1">
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="ValueChanged">
			<body kind="javascript">
				<![CDATA[if (this.Value != OldIsSbros) {
	SetZeroCurrentCell();
	OldIsSbros = this.Value;
}

]]>
			</body>
		</do-on>
	</object>
	<object access-modifier="private" name="OldIsSbros" display-name="OldIsSbros" uuid="57332691-94d6-41ae-8e59-369da0d4f0b3" base-type="notifying_bool" base-type-id="f8797810-1baa-4a1f-af36-cf839bf252e8" ver="5" description="" cardinal="1"/>
	<do access-modifier="private" name="SetZeroCurrentCell" display-name="SetZeroCurrentCell" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
