			<object access-modifier="private" name="Initializer" display-name="Initializer" uuid="61c7bffe-ec26-4f97-944c-2fbc1938531c" base-type="Initializer" base-type-id="6db89679-9299-4993-ad1a-0d086cd1c7d2" ver="5" description="" cardinal="1">
				<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Initialized">
					<body kind="om">
						<![CDATA[
parent.TableModel.AddColumn(Column_bit.Id, Column_bit.Title, Column_bit.Description, "", "string", false, true);
parent.TableModel.AddColumn(Column_desc.Id, Column_desc.Title, Column_desc.Description, "", "string", false, true);
parent.TableModel.AddColumn(Column_decor.Id, Column_decor.Title, Column_decor.Description, "", "uint2", false, true);
TableDecorator.JsonDecorator = TableDecorator.JsonDecorator;

SetDescRow("День", "Время записи");
SetDescRow("Vр, м³", "Объём рабочий");
SetDescRow("Vpв, м³", "Объём востановленный рабочий");
SetDescRow("Vр,сум, м³", "Объём суммарный рабочий");
SetDescRow("Vст, м³", "Объём стандартный");
SetDescRow("Vств, м³", "Объём востановленный стандартный");
SetDescRow("Vст,сум, м³", "Объём суммарный стандартный");
SetDescRow("Pa, МПа", "Давление (абс)");
SetDescRow("Т, °C", "Температура");
SetDescRow("Кпер", "Коэффициент перевода");
SetDescRow("М, кг", "Масса газа");
SetDescRow("Код НС", "Код НС");
SetDescRow("tнс, мин", "Время НС (общий бит НС)");]]>
					</body>
				</do-on>
			</object>
			<do access-modifier="private" name="SetDescRow" display-name="SetDescRow" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
				<body kind="om">
					<![CDATA[rowCount: int4 = TableModel.GetRowCount();
TableModel.AddRow();
TableModel.SetCellData(rowCount, 0, bit);
TableModel.SetCellData(rowCount, 1, desc);
TableModel.SetCellData(rowCount, 2, rowCount%2);
]]>
				</body>
