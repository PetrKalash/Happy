					<![CDATA[rowCount: int4 = TableModel.GetRowCount();
TableModel.AddRow();
TableModel.SetCellData(rowCount, 0, bit);
TableModel.SetCellData(rowCount, 1, desc);
TableModel.SetCellData(rowCount, 2, rowCount%2);
]]>
				</body>
