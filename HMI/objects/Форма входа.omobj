		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="UpdateFinished">
			<body kind="om">
				<![CDATA[Body.ComboBox_UserList.Clear();
//очистка выпадающего списка перед обновлением
i: var = 0;
while (i < Count)
//для всех учетных записей (Count)
{
	Body.ComboBox_UserList.AddItem(GetDisplayName(i));

	//добавление в выпадающий список всех имен пользователей
	UserName[i] = GetLoginName(i);
	//запись соответствующих логинов в массив
	i+=1;
}]]>
			</body>
		</do-on>
	</object>
