			<do-on access-modifier="private" name="Handler_5" display-name="Handler_5" ver="5" event="MouseClick">
				<body kind="om">
					<![CDATA[Timer_1.Active=true;
SecurityContext.AsyncLogin(UserName[ComboBox_UserList.SelectedIndex],Password.PasswordValue);
/*вызов функции AsyncLogin, входными данными для которой являются: 
логин, введенный в поле ComboBox_UserList; 
пароль, введенный в поле TextEdit_Password. */
]]>
