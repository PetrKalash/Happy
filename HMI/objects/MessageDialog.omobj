		<init target="Group" ver="5" ref="unit.WindowGroup.Group"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="MessageReceived">
			<body kind="om">
				<![CDATA[if (messageType=="closeallsame" && messageData!=Window_1.WindowID) {
Close();
}]]>
			</body>
		</do-on>
	</object>
	<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Opened">
		<body kind="om">
			<![CDATA[unit.WindowGroup.Group.SendToAll("closeallsame", Window_1.WindowID);]]>
		</body>
	</do-on>
	<designed target="ShowWindowMaximize" value="false" ver="5"/>
</type>

