	<do-trace access-modifier="private" target="WindowIconPath" ver="5">
		<conditional-expr>
			<condition>
				<![CDATA[Icon == 3]]>
			</condition>
			<expr>
				<![CDATA["CommonLib_Icons/Error16.png"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[Icon == 2]]>
			</condition>
			<expr>
				<![CDATA["CommonLib_Icons/Warning16.png"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[Icon == 1]]>
			</condition>
			<expr>
				<![CDATA["CommonLib_Icons/Question16.png"]]>
			</expr>
		</conditional-expr>
		<default-expr>
			<expr>
				<![CDATA["CommonLib_Icons/Information16.png"]]>
			</expr>
		</default-expr>
	</do-trace>
	<object access-modifier="private" name="AutoClose" display-name="AutoClose" uuid="98e418df-ba7a-43de-ae1c-8bfa0cb8c5ec" base-type="notifying_bool" base-type-id="f8797810-1baa-4a1f-af36-cf839bf252e8" ver="5" description="" cardinal="1">
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="ValueChanged">
			<body kind="om">
				<![CDATA[if (value)
	Close();]]>
			</body>
		</do-on>
	</object>
