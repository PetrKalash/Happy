			<do-on access-modifier="private" name="Handler_2" display-name="Handler_2" ver="5" event="Invoked">
				<body kind="om">
					<![CDATA[if (!parent.Good){
	parent.OpacityTimer.Active = true;
	//here.PenStyle = 1;
	TextBlock.BrushColor = 0xffff0000;
} else {
	here.PenStyle = 0;
	parent.OpacityTimer.Active = false;
	parent.Opacity = 1;
	parent.OpacityTimer.LowHigh = false;
	TextBlock.BrushColor = 0xffffffff;
}]]>
				</body>
			</do-on>
		</object>
