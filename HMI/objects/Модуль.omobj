		<object access-modifier="private" name="OpacityTimer" display-name="OpacityTimer" uuid="dc471f22-84df-4048-b5d2-c12d1821b35e" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
			<designed target="Period" value="5" ver="5"/>
			<designed target="Active" value="false" ver="5"/>
			<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
				<body kind="javascript">
					<![CDATA[if (!LowHigh) {
	parent.Opacity = parent.Opacity - 0.010;
	if (parent.Opacity <= 0) {
		LowHigh = true;	
	}
} else {
	parent.Opacity = parent.Opacity + 0.010;
	if (parent.Opacity >= 1){
		LowHigh = false;	
	}
}
]]>
				</body>
			</do-on>
			<object access-modifier="private" name="LowHigh" display-name="LowHigh" uuid="bca99d2b-1936-4d65-802b-235798a9fcf6" base-type="bool" base-type-id="7c9fe1ab-1ee2-42d8-939f-94ce3e89fca8" ver="5" description="" cardinal="1"/>
