	<object access-modifier="private" name="ValueName" display-name="Название" uuid="923d1ed2-d89b-4090-89b9-f86720473b40" base-type="notifying_string" base-type-id="14976fbf-36ab-415f-abc3-9f8fdc217351" ver="5" description="" cardinal="1"/>
	<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="MouseClick">
		<body kind="om">
			<![CDATA[if (!unit.Source.Connection){
	OpenConnectionDialog();
} else if (!(Security.Access_Operator || Security.Access_Engineer)){
	OpenRightsDialog();
} else if (!(unit.ModeWork.Access || unit.ModeWork.IsPU && unit.ModeWork.ModeWork == 4)) {
	OpenModeDialog();	
} else if (unit.ModeWork.ModeWork == 0) {
	OpenInfoDialog();
} else if (Error) {
	OpenErrorDialog();
} else if (AdminOnly && !unit.Security.Access_Engineer){
	OpenAdminDialog();
} else if (unit.ModeWork.Debug){
	OpenNumpad();
} else if (isPumps) {
	OpenPumps();
} else {
	OpenNumpad();
}



]]>
		</body>
	</do-on>
