	<do access-modifier="private" name="OpenErrorDialog" display-name="OpenErrorDialog" ver="5" form-action="open-dialog" form-by-id="false" type="void">
		<object access-modifier="private" uuid="ee178a72-2748-4ed9-be59-6b9e09a7e91d" base-type="MessageDialog_1" base-type-id="e57be645-5922-4aa1-be96-4629255ec5dc" ver="5">
			<init target="Icon" ver="5" value="3"/>
			<init target="Message" ver="5" ref="ErrorMsg"/>
			<do-trace access-modifier="private" target="WindowIconPath" ver="5">
				<conditional-expr>
					<condition>
						<![CDATA[Icon == 3]]>
					</condition>
					<expr>
						<![CDATA["CommonLib_Icons/Error16.png"]]>
					</expr>
				</conditional-expr>
				<conditional-expr>
					<condition>
						<![CDATA[Icon == 2]]>
					</condition>
					<expr>
						<![CDATA["CommonLib_Icons/Warning16.png"]]>
					</expr>
				</conditional-expr>
				<conditional-expr>
					<condition>
						<![CDATA[Icon == 1]]>
					</condition>
					<expr>
						<![CDATA["CommonLib_Icons/Question16.png"]]>
					</expr>
				</conditional-expr>
				<default-expr>
					<expr>
						<![CDATA["CommonLib_Icons/Information16.png"]]>
					</expr>
				</default-expr>
			</do-trace>
		</object>
	</do>
	<init target="isAlgos" ver="5" value="false"/>
	<init target="isPumps" ver="5" value="false"/>
