			<do access-modifier="private" name="CheckWarnings" display-name="CheckWarnings" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
				<body kind="om">
					<![CDATA[
CheckCranes();
CheckAlgos();
CheckSubAlgos();
if (Body.Table.Model.GetRowCount() > 0){
	Body.Table.Visible = true;
	Label.Text = "Следующие сигналы могут привести к некоректной работе станции или к непреднамеренной активации алгоритмов. Перейти в Автоматизированный режим?";
	Label.FontColor = 0xffff0000;
	here.WindowName = "ВНИМАНИЕ!!!";
	

	here.Body.AcceptBtn.Visible = true;
	
	
	
	here.Height = 420;
	AcceptBtn.Visible = true;
	
	AcceptBtn.Y = 315;
	

	return;
} else {
Accept_A=true;
	Close();
}



]]>
				</body>
			</do>
		</object>
