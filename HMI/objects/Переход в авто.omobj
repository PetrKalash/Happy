	<init target="WindowName" ver="5" value="Проверка условий перехода в
Автоматический режим"/>
	<init target="ShowClose" ver="5" value="false"/>
	<do access-modifier="private" name="CheckCranes" display-name="CheckCranes" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
		<body kind="javascript">
			<![CDATA[

for (let i = 0; i < 25; i++){
	let msg = unit.Cranes.CheckCrane(unit.Cranes.CranesArray[i].Value, unit.Cranes.CranesArray[i].Name, unit.Cranes.CranesArray[i].Status, unit.Cranes.CranesArray[i].line_TS_O, unit.Cranes.CranesArray[i].line_TS_C, unit.Cranes.CranesArray[i].Status_line_TU_O, unit.Cranes.CranesArray[i].Status_line_TU_C);
	if (msg.length != 0 ) {
		Body.Table.Model.AddRow();
		Body.Table.Model.SetCellData(Body.Table.Model.GetRowCount()-1, 0, msg);

	}; 
}
]]>
		</body>
	</do>
	<do access-modifier="private" name="CheckAlgos" display-name="CheckAlgos" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
		<body kind="javascript">
			<![CDATA[
for (let i = 0; i < unit.Algos.AO_BS_Bypass.Trigger.Length; i++){
    if (unit.Algos.AO_BS_Bypass.Trigger[i].Value) {
        Body.Table.Model.AddRow();
		Body.Table.Model.SetCellData(Body.Table.Model.GetRowCount()-1, 0, "АОб с переходом на байпас: " + unit.Algos.AO_BS_Bypass.Trigger[i].Text);
    }
}
for (let i = 0; i < unit.Algos.AO_PP_BS.Trigger.Length; i++){
    if (unit.Algos.AO_PP_BS.Trigger[i].Value) {
        Body.Table.Model.AddRow();
		Body.Table.Model.SetCellData(Body.Table.Model.GetRowCount()-1, 0, "АОППб: " + unit.Algos.AO_PP_BS.Trigger[i].Text);
    }
}
for (let i = 0; i < unit.Algos.AO_PP_S.Trigger.Length; i++){
    if (unit.Algos.AO_PP_S.Trigger[i].Value) {
        Body.Table.Model.AddRow();
		Body.Table.Model.SetCellData(Body.Table.Model.GetRowCount()-1, 0, "АОППс: " + unit.Algos.AO_PP_S.Trigger[i].Text);
    }
}
for (let i = 0; i < unit.Algos.AO_S_Bypass.Trigger.Length; i++){
    if (unit.Algos.AO_S_Bypass.Trigger[i].Value) {
