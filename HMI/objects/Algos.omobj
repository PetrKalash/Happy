			<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Initialized">
				<body kind="javascript">
					<![CDATA[let triggerArray = [
	{
		path: "Alarm.P_gas_out1._12max",
		text: "Повышение давления на выходе ГРС на 12%"	
	},
	{
		path: "Alarm.P_gas_out1._12min",
		text: "Понижение давления на выходе ГРС на 12%"	
