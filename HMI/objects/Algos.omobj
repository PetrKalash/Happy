		<object access-modifier="private" name="Initialize_Cran" display-name="Initialize_Cran" uuid="ec239667-cec4-4d4c-b047-5d8ed50c7d3f" base-type="Initializer" base-type-id="6db89679-9299-4993-ad1a-0d086cd1c7d2" ver="5" description="" cardinal="1">
			<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Initialized">
				<body kind="javascript">
					<![CDATA[	let cranePathArray = [

	{
        path: "CR_1_3",
        name: "Кран 1-3",
        status: 2
    },
	{
        path: "CR_1_1",
        name: "Кран 1-1",
        status: 1
    },
	{
        path: "CR_1_2",
        name: "Кран 1-2",
        status: 1
    }

];

cranePathArray.forEach((crane, index) => {
	CranesArray[index].Path = crane.path + ".TS_Status";
	CranesArray[index].Name = crane.name;
	CranesArray[index].Status = crane.status;
	CranesArray[index].line_TS_O.Path = crane.path + ".line_TS_O";
	CranesArray[index].line_TS_C.Path = crane.path + ".line_TS_C";
	CranesArray[index].Status_line_TU_O.Path = crane.path + ".Status_line_TU_O";
	CranesArray[index].Status_line_TU_C.Path = crane.path + ".Status_line_TU_C";
})

 ]]>
				</body>
			</do-on>
		</object>
	</object>
	<object access-modifier="private" name="Drain_cond1" display-name="Drain_cond1" uuid="63461563-26dc-422b-b249-b3558846876b" base-type="Folder" base-type-id="6b532336-2e8c-41e5-a6b7-2d505e6d5e0b" ver="5" description="" cardinal="1">
