		<do access-modifier="private" name="CheckCranes" display-name="CheckCranes" ver="5" type="string" type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d">
			<body kind="javascript">
				<![CDATA[let arrCranes = this.CranesArray;

let msg = [];

for (let i = 0; i < arrCranes.Length; i++){
	msg.push( unit.Cranes.CheckCrane(
	CranesArray[i].Value,
	CranesArray[i].Name,
	CranesArray[i].Status, 
	CranesArray[i].line_TS_O, 
	CranesArray[i].line_TS_C, 
	CranesArray[i].Status_line_TU_O, 
	CranesArray[i].Status_line_TU_C));
	
	if ( FirstTrue && msg.length > 0) {
		return msg[0];
	}
}

return msg.join(",");]]>
			</body>
