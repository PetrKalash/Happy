			<body kind="javascript">
				<![CDATA[let arr = this.Trigger;


let msg = []; // Массив сообщений

for (let i = 0; i< arr.Length; i++) {
	if (arr[i].Value) {		
		msg.push(arr[i].Text);
		if (FirstTrue) {
			return msg[0];
			
		}		
	} 
}

return msg.join(",");]]>
			</body>
			<param access-modifier="private" name="FirstTrue" display-name="" uuid="666ac6aa-496a-4382-99ba-5ba97e717396" base-type="bool" base-type-id="7c9fe1ab-1ee2-42d8-939f-94ce3e89fca8" ver="5"/>
