	<object access-modifier="private" name="Pump_heat_UPT" display-name="Pump_heat_UPT" uuid="dbac22c6-387a-4e18-8b37-18247017617d" base-type="Folder" base-type-id="6b532336-2e8c-41e5-a6b7-2d505e6d5e0b" ver="5" description="" cardinal="1">
		<object access-modifier="private" name="Trigger" display-name="Trigger" uuid="a9d95285-4d01-485b-a4b7-714769a74d54" base-type="ApItemBool" base-type-id="e3f11724-0f76-4497-8d01-38fbb82fb844" ver="5" description="" cardinal="2">
			<init target="Source" ver="5" ref="unit.Source.Main"/>
			<object access-modifier="private" name="Text" display-name="Text" uuid="50607db4-2ee8-49e0-83af-b037a0d1be5a" base-type="string" base-type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d" ver="5" description="" cardinal="1"/>
		</object>
		<do access-modifier="private" name="CheckAlgoRedy" display-name="CheckAlgoRedy" ver="5" type="string" type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d">
			<body kind="javascript">
				<![CDATA[let arr = this.Trigger;


let msg = []; // Массив сообщений

for (let i = 0; i< arr.Length; i++) {
	if (arr[i].Value) {		
		msg.push(arr[i].Text);
		if (FirstTrue) {
			return msg[0];
			
		}		
	} 
}

return msg.join(",");]]>
			</body>
			<param access-modifier="private" name="FirstTrue" display-name="" uuid="7affccff-aa4d-4538-8fa3-0916a708435f" base-type="bool" base-type-id="7c9fe1ab-1ee2-42d8-939f-94ce3e89fca8" ver="5"/>
		</do>
