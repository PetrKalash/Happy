			<object access-modifier="private" name="Text" display-name="Text" uuid="51d7b298-ff98-465a-883c-5bd6d79dcfbe" base-type="string" base-type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d" ver="5" description="" cardinal="1"/>
