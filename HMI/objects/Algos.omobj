		<do access-modifier="private" name="CheckAlgoRedy" display-name="CheckAlgoRedy" ver="5" type="string" type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d">
			<body kind="javascript">
				<![CDATA[let arr = this.Trigger;


let msg = []; // Массив сообщений

for (let i = 0; i< arr.Length; i++) {
	if (arr[i].Value) {		
		msg.push(arr[i].Text);
		if (FirstTrue) {
			return msg[0];
			
		}		
	} 
}

return msg.join(",");]]>
			</body>
			<param access-modifier="private" name="FirstTrue" display-name="" uuid="f006f106-1b05-4449-88c3-0a03d54e6cb3" base-type="bool" base-type-id="7c9fe1ab-1ee2-42d8-939f-94ce3e89fca8" ver="5"/>
		</do>
		<do access-modifier="private" name="CheckCranes" display-name="CheckCranes" ver="5" type="string" type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d">
			<body kind="javascript">
				<![CDATA[let arrCranes = this.CranesArray;

let msg = [];

for (let i = 0; i < arrCranes.Length; i++){
	msg.push( unit.Cranes.CheckCrane(
	CranesArray[i].Value,
	CranesArray[i].Name,
	CranesArray[i].Status, 
	CranesArray[i].line_TS_O, 
	CranesArray[i].line_TS_C, 
	CranesArray[i].Status_line_TU_O, 
	CranesArray[i].Status_line_TU_C));
	
	if ( FirstTrue && msg.length > 0) {
		return msg[0];
	}
}

return msg.join(",");]]>
			</body>
			<param access-modifier="private" name="FirstTrue" display-name="" uuid="41d610b9-f987-4689-baea-7f07d982eaab" base-type="bool" base-type-id="7c9fe1ab-1ee2-42d8-939f-94ce3e89fca8" ver="5"/>
		</do>
		<object access-modifier="private" name="Initialize" display-name="Initialize" uuid="3689a8d5-29e5-49e3-b389-34742c807685" base-type="Initializer" base-type-id="6db89679-9299-4993-ad1a-0d086cd1c7d2" ver="5" description="" cardinal="1">
			<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Initialized">
				<body kind="javascript">
					<![CDATA[	let triggerArray = [
	{
		path: "Alarm.P_gas_out1._15max",
		text: "Повышение давления на выходе ГРС на 15%"	
	},
	{
		path: "EKM.Out1_high",
		text: "ЭКМ: Повышение давления на выходе ГРС"	
	},
	{
		path: "Alarm.P_gas_out1._15min",
		text: "Понижение давления на выходе ГРС на 15%"	
	},
	{
		path: "EKM.Out1_low",
		text: "ЭКМ: Понижение давления на выходе ГРС"	
	},
	{
		path: "AI_Sensors.P_gas_out1.Status"	,
		text: "Неисправность датчика давления на выходе ГРС"
	},
	{
		path: "Alarm.P_gas_in._15min",
		text: "Понижение давления на входе на 15%"
	},
	{
		path: "EKM.In_low"	,
		text: "ЭКМ: Понижение давления на входе ГРС"
	},
	{
		path: "AI_Sensors.P_gas_in.Status",
		text: "Неисправность датчика давления на входе ГРС"
	},
	{
		path: "Alarm.P_delta_in",
		text: "Резкое понижение давления на входе ГРС"
	},
	{
		path: "Algos.AO_BS.StatusError"	,
		text: "Ошибка алгоритма"
	},
	{
		path: "Algos.AO_BS.StatusSuccess",
		text: "Необходимо сбросить алгоритм"	
	}
]

for (let i = 0; i < triggerArray.length; i++) {
	Trigger[i].Path = triggerArray[i].path.trim();
	Trigger[i].Text = triggerArray[i].text;
}]]>
				</body>
			</do-on>
		</object>
		<object access-modifier="private" name="Initialize_Cran" display-name="Initialize_Cran" uuid="06661f74-db3c-4a19-a1be-f21d2b3b51e4" base-type="Initializer" base-type-id="6db89679-9299-4993-ad1a-0d086cd1c7d2" ver="5" description="" cardinal="1">
			<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Initialized">
				<body kind="javascript">
					<![CDATA[let cranePathArray = [
	 {
        path: "CR_1_1",
        name: "Кран 1-1",
        status: 1
    },	
    {
        path: "CR_1_2",
        name: "Кран 1-2",
        status: 1
    },	   
    {
        path: "CR_1_3",
        name: "Кран 1-3",
        status: 2
    }
];

cranePathArray.forEach((crane, index) => {
	CranesArray[index].Path = crane.path + ".TS_Status";
	CranesArray[index].Name = crane.name;
	CranesArray[index].Status = crane.status;
	CranesArray[index].line_TS_O.Path = crane.path + ".line_TS_O";
	CranesArray[index].line_TS_C.Path = crane.path + ".line_TS_C";
	CranesArray[index].Status_line_TU_O.Path = crane.path + ".Status_line_TU_O";
	CranesArray[index].Status_line_TU_C.Path = crane.path + ".Status_line_TU_C";
})

 ]]>
				</body>
			</do-on>
		</object>
	</object>
