			<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Initialized">
				<body kind="javascript">
					<![CDATA[let triggerArray = [
	{
		path: "UPT.Mode_Bool",
		text: "Ручное управление запрещено в текущем режиме работы ШУПТ. Для управления ШУПТ, переведите его в режим работы от САУ"
	},
	{
		path: "Algos.Pump_heat_UPT.Alarm",
		text: "Работа насосов подогрева: Управление алгоритмом запрещено в связи с ошибкой алгоритма. Необходимо сбросить алгоритм"
	}
]

for (let i = 0; i < triggerArray.length; i++) {
	Trigger[i].Path = triggerArray[i].path;
	Trigger[i].Text = triggerArray[i].text;
}]]>
				</body>
			</do-on>
		</object>
	</object>
