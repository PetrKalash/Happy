	<object access-modifier="private" name="NumberChannelCounter" display-name="NumberChannelCounter" uuid="82165e7a-a926-4ae5-ba9e-383edd0bf2e0" base-type="int4" base-type-id="74222947-f188-4195-8e0e-e33bd9827255" ver="5" description="" cardinal="1"/>
	<object access-modifier="private" name="Timer" display-name="Timer" uuid="efeb6c74-4a46-466d-9260-d3ee2931326a" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
		<designed target="Period" value="200" ver="5"/>
		<designed target="Active" value="true" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
			<body kind="javascript">
				<![CDATA[for (let i = 0; i < Body.Column.Length; i++) {
	for (let j = 0; j < Body.Column[i].DIData.Length; j++) {
		Body.Column[i].DIData[j].Channel.Text_1.Text = ++NumberChannelCounter;
		Body.Column[i].DIData[j].CurrentValue.Settings.InvertPath = Body.Column[i].DIData[j].InvertPath;
		Body.Column[i].DIData[j].CurrentValue.Settings.SignalPath = Body.Column[i].DIData[j].PathSignal;
	}
}
me.Active = false;]]>
			</body>
		</do-on>
	</object>
	<object access-modifier="private" name="Timer2" display-name="Timer2" uuid="da98d46a-92e3-478f-99d7-663d704cf029" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
		<designed target="Period" value="300" ver="5"/>
		<designed target="Active" value="true" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
			<body kind="javascript">
				<![CDATA[for (let i = 0; i < Body.Column.Length; i++) {
	for (let j = 0; j < Body.Column[i].DIData.Length; j++) {
		Body.Column[i].DIData[j].Parameter.Text_1.Text = Body.Column[i].DIData[j].NameSignal;
		Body.Column[i].DIData[j].CurrentValue.Settings.Name = Body.Column[i].DIData[j].NameSignal;
	}
}]]>
			</body>
		</do-on>
	</object>
	<object access-modifier="private" name="LayoutMargins" display-name="LayoutMargins" uuid="9d8e8396-d79d-4d39-9ff2-d5df623387f1" base-type="LayoutMargins" base-type-id="d86ce751-1ea7-42c6-8d4b-10c651a2727d" ver="5" description="" cardinal="1">
		<designed target="Top" value="40" ver="5"/>
