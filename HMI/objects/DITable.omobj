	<object access-modifier="private" name="Timer3" display-name="Timer3" uuid="b60efb92-cd57-4fae-b380-0a729c99e77f" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
		<designed target="Period" value="1000" ver="5"/>
		<designed target="Active" value="true" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
			<body kind="javascript">
				<![CDATA[for (let i = 0; i < Body.Column.Length; i++) {
	for (let j = 0; j < Body.Column[i].DIData.Length; j++) {
	
		if (Body.Column[i].DIData[j].IncorrectValue.Value) {
		   Body.Column[i].DIData[j].Parameter.PenColor = "0xffaa00ff";
		   Body.Column[i].DIData[j].Parameter.PenWidth = 2;
		}
		
		let cell = Body.Column[i].DIData[j].NameSignal.Value;
		let name = cell || '';
        
		if (!Body.Column[i].DIData[j].CurrentValue.Settings.SignalParam.Advised
		&& !Body.Column[i].DIData[j].IncorrectValue.Value
		&& !/^резерв$/i.test(name.trim())) {
			Body.Column[i].DIData[j].Parameter.PenColor = "0xffff0000";
			Body.Column[i].DIData[j].Parameter.PenWidth = 2;
		}
	}
}
me.Active = false;]]>
			</body>
		</do-on>
	</object>
</type>

