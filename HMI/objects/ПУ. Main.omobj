	<object access-modifier="private" name="Window" display-name="Window" uuid="6a609e3c-75a6-4481-8cb5-0a9d48230de7" base-type="Window" base-type-id="04615219-28bb-4a9a-bba4-50ac66972eb0" ver="5" description="" cardinal="1">
		<init target="Group" ver="5" ref="unit.WindowGroup.Main"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="MessageReceived">
			<body kind="om">
				<![CDATA[
if (messageType == "LogOff") {
AlarmJournal_1.Alarms_1.LogOn( unit.Security.SecurityContext.CurrentUser);
}
if (messageType == "LogOn") {
AlarmJournal_1.Alarms_1.LogOn( unit.Security.SecurityContext.CurrentUser);
}

if (messageType == "bottom") {
	AlarmJournal_1.Visible = true;
	Logo.Visible = true;

	AlarmJournal_1.Y = 953;
	AlarmJournal_1.Alarms_1.DisplayToolbar = false;
	AlarmJournal_1.Alarms_1.DisplayStatePanel = false;
	AlarmJournal_1.Alarms_1.ActiveMode = 0;
	AlarmJournal_1.Width = 1920;
	AlarmJournal_1.Height = 125;
	
	AlarmJournal_1.Alarms_1.FollowLatestEvent=true;
	AlarmJournal_1.Alarms_1.X = 0;
	AlarmJournal_1.Alarms_1.Y = 0;
	AlarmJournal_1.Alarms_1.Width = 1920;
	AlarmJournal_1.Alarms_1.Height = 125;
	AlarmJournal_1.Alarms_1.Scale = 1;
	
	AlarmJournal_1.Alarms_1.VerticalScrollBarPolicy=1;
	AlarmJournal_1.Alarms_1.HorizontalScrollBarPolicy=1;
	//AlarmJournal_1.Alarms_1.LoadConfiguration("BottomConfig");
	AlarmJournal_1.Alarms_1.SetAdvancedFilter("severity", "600 | 400");
	
	AlarmJournal_1.Alarms_1.SetAdvancedFilter("message", "");	
	
	
}
if (messageType == "hide") {
	AlarmJournal_1.Visible = false;
	Logo.Visible = false;
}
if (messageType == "full") {
	AlarmJournal_1.Visible = true;
	AlarmJournal_1.Alarms_1.DisplayToolbar = true;
	AlarmJournal_1.Alarms_1.DisplayStatePanel = true;

	AlarmJournal_1.Y = 100;
	Logo.Visible=false;
	AlarmJournal_1.Alarms_1.ActiveMode = 0;
	AlarmJournal_1.Width = 1920;
	AlarmJournal_1.Height = 900;
	
	AlarmJournal_1.Alarms_1.FollowLatestEvent=false;
	AlarmJournal_1.Alarms_1.X = 220;
	AlarmJournal_1.Alarms_1.Y = 110;
	AlarmJournal_1.Alarms_1.Height = 729;
	AlarmJournal_1.Alarms_1.Width = 1480;
	AlarmJournal_1.Alarms_1.Scale = 1.3;
		AlarmJournal_1.Alarms_1.VerticalScrollBarPolicy=0;
	AlarmJournal_1.Alarms_1.HorizontalScrollBarPolicy=0;
	AlarmJournal_1.Alarms_1.SetAdvancedFilter("severity", "");
	//	AlarmJournal_1.Alarms_1.LoadConfiguration("FullConfig");
}

]]>
			</body>
		</do-on>
	</object>
