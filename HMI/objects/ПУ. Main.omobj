	<object access-modifier="private" name="Kvit_btn" display-name="Kvit_btn" uuid="e0929545-104d-4936-a5ca-90ad3c014bd1" base-type="ApItemBool" base-type-id="e3f11724-0f76-4497-8d01-38fbb82fb844" ver="5" description="" cardinal="1">
		<init target="Source" ver="5" ref="unit.Source.Main"/>
		<init target="Path" ver="5" value="Signals.Kvit_btn"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnValueChanged">
			<body kind="om">
				<![CDATA[if (value){
	if (!unit.Security.Access_Operator && !unit.Security.Access_Engineer) {
		if (!unit.ModeWork.Kvit_window){
			NoAccessAction.Invoke();
			unit.ModeWork.Kvit_window = true;		
		}
		return;
	}
	Kvit_signal.In = true;
}

if (!value) Kvit_signal.In = false;
]]>
			</body>
		</do-on>
	</object>
