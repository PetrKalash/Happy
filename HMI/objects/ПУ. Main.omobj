		<do access-modifier="private" name="CheckSubAuto" display-name="CheckSubAuto" ver="5" form-action="open-dialog" form-by-id="false" type="void">
			<object access-modifier="private" uuid="cb745bf9-2fd0-48db-8c9e-690763e3116f" base-type="Переход в авто_1" base-type-id="e61527c9-9dae-45cb-9986-e28abc342e28" ver="5">
