	<object access-modifier="private" name="Unit" display-name="Unit" uuid="8bf5da47-e9dc-4bec-8d8d-c80b643e7454" base-type="notifying_string" base-type-id="14976fbf-36ab-415f-abc3-9f8fdc217351" ver="5" description="" cardinal="8"/>
	<object access-modifier="private" name="UnitInit" display-name="UnitInit" uuid="c6c3b2e1-d9a0-4fef-b6b8-c4e9a9098132" base-type="Initializer" base-type-id="6db89679-9299-4993-ad1a-0d086cd1c7d2" ver="5" description="" cardinal="1">
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Initialized">
			<body kind="om">
				<![CDATA[Unit[0] = "МПа";
Unit[1] = "кгс/см²";
Unit[2] = "кПа";
Unit[3] = "бар";
Unit[4] = "кгс/м²";
Unit[5] = "°C";
Unit[6] = "%";
Unit[7] = "В";]]>
			</body>
		</do-on>
	</object>
