	<do access-modifier="private" name="Pretify" display-name="Pretify" ver="5" type="string" type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d">
		<body kind="javascript">
			<![CDATA[let n = value.toString();
return n.replace(/(\d{1,3}(?=(?:\d\d\d)+(?!\d)))/g, "$1" + " ");]]>
		</body>
		<param access-modifier="private" name="value" display-name="" uuid="0d775a25-e387-4099-900b-b9ab6f9ea0c2" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5"/>
	</do>
	<do access-modifier="private" name="Floor" display-name="Floor" ver="5" type="uint4" type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e">
		<body kind="javascript">
			<![CDATA[return Math.floor(value);]]>
		</body>
		<param access-modifier="private" name="value" display-name="" uuid="ece2a449-e51e-45f3-ac4a-2bb9b2641d9e" base-type="float" base-type-id="730a70b7-31fd-42cf-860d-ba8faa618f9d" ver="5"/>
	</do>
	<do access-modifier="private" name="UnPretify" display-name="UnPretify" ver="5" type="uint4" type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e">
		<body kind="om">
			<![CDATA[return String.ToUint4(String.Replace(value, " ", ""),0);]]>
		</body>
		<param access-modifier="private" name="value" display-name="" uuid="beccb3dc-cf8e-4ac9-9b8f-e8c145ab9154" base-type="string" base-type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d" ver="5"/>
	</do>
	<do access-modifier="private" name="ToHex" display-name="ToHex" ver="5" type="string" type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d">
		<body kind="javascript">
			<![CDATA[return value.toString(16);]]>
		</body>
		<param access-modifier="private" name="value" display-name="" uuid="6ef82ec4-ee47-4223-96c3-efb97b8f2d5c" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5"/>
	</do>
