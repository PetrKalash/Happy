	<do access-modifier="private" name="hexToRGB" display-name="hexToRGB" ver="5" type="variant" type-id="7d3322c1-a2cf-4732-a957-abd69e3e4b7a">
		<body kind="javascript">
			<![CDATA[str = hex.toString(16);

const a = parseInt(hex.slice(0, 2), 16);
const r = parseInt(hex.slice(2, 4), 16);
const g = parseInt(hex.slice(4, 6), 16);
const b = parseInt(hex.slice(6, 8), 16);
return { r, g, b };]]>
		</body>
		<param access-modifier="private" name="hex" display-name="" uuid="58c793be-d099-409b-8e67-49cf9b925ea9" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5"/>
	</do>
