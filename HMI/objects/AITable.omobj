	<object access-modifier="private" name="Timer3" display-name="Timer3" uuid="c77b4b2b-c1fd-47cd-9f89-71eba20f1b72" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
		<designed target="Period" value="1000" ver="5"/>
		<designed target="Active" value="true" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
			<body kind="javascript">
				<![CDATA[for (let i = 0; i < Body.AIData.Length; i++) {
	if (Body.AIData[i].IncorrectValue.Value) {
	   Body.AIData[i].Parameter.PenColor = "0xffaa00ff";
	   Body.AIData[i].Parameter.PenWidth = 2;
	}
	if (!Body.AIData[i].CurrentValue.Settings.AIValue.Advised && !Body.AIData[i].IncorrectValue.Value) {
		Body.AIData[i].Parameter.PenColor = "0xffff0000";
		Body.AIData[i].Parameter.PenWidth = 2;
	}
}
me.Active = false;]]>
			</body>
		</do-on>
	</object>
