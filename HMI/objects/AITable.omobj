	<object access-modifier="private" name="Timer" display-name="Timer" uuid="0e8dd67b-a8b1-4ee7-9b09-02c32e6b6e5c" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
		<designed target="Period" value="200" ver="5"/>
		<designed target="Active" value="true" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
			<body kind="javascript">
				<![CDATA[for (let i = 0; i < Body.AIData.Length; i++) {
	Body.AIData[i].Channel.Text_1.Text = String(Body.AIData[i].NumberChannel);
	Body.AIData[i].CurrentValue.Settings.AIPath = Body.AIData[i].PathSignal;
}
for (let i = CountChannels; i < Body.AIData.Length; i++) {
	Body.AIData[i].Visible = false;
}
me.Active = false;]]>
			</body>
		</do-on>
	</object>
	<object access-modifier="private" name="Timer2" display-name="Timer2" uuid="7d1e5d56-be43-42d0-b27a-ab376c1c0e99" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
		<designed target="Period" value="300" ver="5"/>
		<designed target="Active" value="true" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
			<body kind="javascript">
				<![CDATA[for (let i = 0; i < Body.AIData.Length; i++) {
	Body.AIData[i].Parameter.Text_1.Text = Body.AIData[i].NameSignal + ", " + Body.AIData[i].CurrentValue.Settings.Unit;
}]]>
			</body>
		</do-on>
	</object>
