		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
			<body kind="om">
				<![CDATA[if (GVL.strSeverity == "400") { Body.AlarmMessage.Alarm.Tag_alarm.Text = "НЕИСПРАВНОСТЬ ГРС"; Body.AlarmMessage.Alarm.PenColor = 0xffffff00; }
else if (GVL.strSeverity == "600") { Body.AlarmMessage.Alarm.Tag_alarm.Text = "АВАРИЯ ГРС"; Body.AlarmMessage.Alarm.PenColor = 0xffff3333; }
else { Body.AlarmMessage.Alarm.Tag_alarm.Text = "Неисправность ГРС"; Body.AlarmMessage.Alarm.PenColor = 0xffff3333; }]]>
			</body>
		</do-on>
