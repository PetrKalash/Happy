	</object>
	<object access-modifier="private" name="TouchScreenTimer" display-name="TouchScreenTimer" uuid="7be0aede-2f51-4b4c-8dfe-cc287464e2fd" base-type="Timer" base-type-id="72ba7cd4-549e-41f2-923c-2431b91f349a" ver="5" description="" cardinal="1">
		<designed target="Period" value="1000" ver="5"/>
		<designed target="Active" value="true" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
			<body kind="javascript">
				<![CDATA[TouchScreen.isSbrosCurrentCell = Alarms_1.Toolbar.Visible;

let OldVersionAlarms = Alarms_1.AlarmsTable.Main_tables_Operative.Table_Operative_mode;

TouchScreen.Width = OldVersionAlarms.Width-20;
TouchScreen.X = Alarms_1.X;


TouchScreen.Height = OldVersionAlarms.Height - Alarms_1.Statusbar.Height;
TouchScreen.Y = Alarms_1.Y + 60;

if ( Alarms_1.Toolbar.Visible == true ){
 TouchScreen.Y = TouchScreen.Y + Alarms_1.Toolbar.Height;
}
TouchScreen.Scale = Alarms_1.Scale;

// TouchScreen.Y = TouchScreen.Y  + Alarms_1.AlarmsTable.TableOne.HeaderHeight * Alarms_1.Scale;

]]>
			</body>
		</do-on>
	</object>
