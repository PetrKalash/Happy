			<designed target="Enabled" value="true" ver="5"/>
			<designed target="InvokeTrigger" value="false" ver="5"/>
			<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Invoked">
				<body kind="javascript">
					<![CDATA[//unit.Source.DebugTool_1.Log(Alarms_1.Scale);
//unit.Source.DebugTool_1.Log(TouchScreen.CustomTable.GetRowCount() - 1);
if (Alarms_1.Scale == 1) {
	if (TouchScreen.CurrentCell > 30) {
			TouchScreen.CurrentCell = 30;
	}	
	
} else {
	if (TouchScreen.CurrentCell > TouchScreen.CustomTable.GetRowCount()) {
			TouchScreen.CurrentCell = TouchScreen.CustomTable.GetRowCount() - 1;
	}
}]]>
				</body>
			</do-on>
		</object>
