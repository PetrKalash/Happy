		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnValueChanged">
			<body kind="om">
				<![CDATA[if (value) {
	Body.TitleBody.Action_text.Text = "Ошибка формирования отчета";
	Body.TitleBody.Action_text.FontColor = 0xffff0000;
	Body.TitleBody.Action_text.Image.Timer.Active = false;
	Body.TitleBody.Action_text.Image.Rotation = 0;
	Body.TitleBody.Action_text.Image.ImageFile = "remove.png"; 
	Body.ProgressBar.Value = Body.ProgressBar.MaxLimit;
	Body.ProgressBar.ProgressBar_text.Text = "-";
}]]>
			</body>
		</do-on>
	</object>
	<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Opened">
		<body kind="om">
			<![CDATA[Start=true;
Row_read.In=0;

if (GetLogs) {
	OpenLogs.Invoke();
}]]>
		</body>
	</do-on>
	<object access-modifier="private" name="Row_ready" display-name="Row_ready" uuid="554b4638-b4c3-47de-8e1e-f504c2436a52" base-type="ApItemInt2" base-type-id="46c29e2c-cf0c-4e96-ad30-6d7ae4e2ae8c" ver="5" description="" cardinal="1">
		<init target="Path" ver="5" value="Row_ready"/>
		<init target="Source" ver="5" ref="Source_Archive"/>
		<object access-modifier="private" name="Row_realy_ready" display-name="Row_realy_ready" uuid="812617f3-2633-43d7-94ac-1f33db9004a6" base-type="notifying_bool" base-type-id="f8797810-1baa-4a1f-af36-cf839bf252e8" ver="5" description="" cardinal="1">
			<do-on access-modifier="private" name="Handler_3" display-name="Handler_3" ver="5" event="ValueChanged">
				<body kind="om">
					<![CDATA[if (value) {

	rowCount: int4 = Body.Archive_table.TableModel.GetRowCount();
	if (rowCount == 0) {
		Body.Archive_table.AddNewRow();

		
	} else if (!String.Equals(Variant.ToString(Body.Archive_table.TableModel.GetCellData(rowCount-1, 0), ""), Source_Archive.Arch_date)) {
		Body.Archive_table.AddNewRow();
	
	} 
	
}]]>
				</body>
			</do-on>
		</object>
		<do-trace access-modifier="private" target="Row_realy_ready" ver="5">
			<body>
				<![CDATA[Row_ready > Variant.ToInt2(Row_read.In, 0) && Row_ready != 0 && Row_ready.Quality == 192 && Row_read.In.Quality == 216]]>
			</body>
		</do-trace>
	</object>
