			<object access-modifier="private" name="Info_text" display-name="Info_text" uuid="4eaa660b-ebee-48e7-80d3-250bd05c5448" base-type="Text" base-type-id="21d59f8d-2ca4-4592-92ca-b4dc48992a0f" ver="5" description="" cardinal="1">
