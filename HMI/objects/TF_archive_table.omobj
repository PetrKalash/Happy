		<object access-modifier="private" name="Archive_table" display-name="Archive_table" uuid="7d65e27d-990a-4a36-8ba0-fbda0ac773fd" base-type="Table" base-type-id="c65ff4dc-f22b-47d3-9333-72c4e4e5f662" ver="5" description="" cardinal="1">
			<designed target="X" value="10" ver="5"/>
