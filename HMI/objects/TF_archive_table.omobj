				<object access-modifier="private" name="V_st" display-name="V_st" uuid="16d73534-2d71-427d-ab6b-2ec730dd62ae" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5" description="" cardinal="1"/>
