				<object access-modifier="private" name="V_st_sum" display-name="V_st_sum" uuid="2834d921-c71d-48ff-a5a9-6e08e4ed9811" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5" description="" cardinal="1"/>
