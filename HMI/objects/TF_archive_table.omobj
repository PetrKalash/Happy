		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnValueChanged">
			<body kind="om">
				<![CDATA[if (value) {
	Body.TitleBody.Action_text.Text = "Архив успешно сформирован. Время формирования: " + DateTime.ToString(DateTime.Now());
	Body.TitleBody.Action_text.FontColor = 0xff00ff00;
	Body.TitleBody.Action_text.Image.Timer.Active = false;
	Body.TitleBody.Action_text.Image.Rotation = 0;
	Body.TitleBody.Action_text.Image.ImageFile = "check.png"; 
	Body.ProgressBar.Value = Body.ProgressBar.MaxLimit;
	Body.ProgressBar.ProgressBar_text.Text = "100%";
	Body.Archive_table.SetFinalRow();
}]]>
			</body>
		</do-on>
	</object>
	<object access-modifier="private" name="Error" display-name="Error" uuid="9298cf43-8619-4305-b72e-4c1234761e49" base-type="ApItemBool" base-type-id="e3f11724-0f76-4497-8d01-38fbb82fb844" ver="5" description="" cardinal="1">
