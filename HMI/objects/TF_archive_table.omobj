					<body kind="javascript">
						<![CDATA[var name = SaveTF.PathName.Value;
var replaced = name.replace(/\\/, "\/\/");

if (SaveTF.ButtonPress.Value) {
	Body.Archive_table_for_print.Save("//" + replaced, "xlsx");
	DebugTool_1.Log("//" + replaced);
	SaveTF.ButtonPress.Value = false;
}
]]>
					</body>
				</do-on>
