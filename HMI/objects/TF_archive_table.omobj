			<object access-modifier="private" name="Final" display-name="Final" uuid="d2bb388c-6a09-4794-8816-2c123e1eece1" base-type="Folder" base-type-id="6b532336-2e8c-41e5-a6b7-2d505e6d5e0b" ver="5" description="" cardinal="1">
				<object access-modifier="private" name="V_work" display-name="V_work" uuid="56cb95e6-b81c-4689-be6f-62bd51e49d89" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5" description="" cardinal="1"/>
				<object access-modifier="private" name="V_work_vost" display-name="V_work_vost" uuid="9c713199-7c0c-49b7-bb85-d64dd6109e41" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5" description="" cardinal="1"/>
				<object access-modifier="private" name="V_work_sum" display-name="V_work_sum" uuid="25ef9c9a-552c-487b-9ff2-1a3ae123403b" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5" description="" cardinal="1"/>
				<object access-modifier="private" name="V_st" display-name="V_st" uuid="2ab75307-8228-405f-a3ed-32b47c464f2f" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5" description="" cardinal="1"/>
				<object access-modifier="private" name="V_st_vost" display-name="V_st_vost" uuid="1307de03-d20b-48c6-8dca-7838454b73d9" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5" description="" cardinal="1"/>
				<object access-modifier="private" name="V_st_sum" display-name="V_st_sum" uuid="38740901-a594-4fb3-a620-e95bca5d1d78" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5" description="" cardinal="1"/>
			</object>
			<do access-modifier="private" name="AddNewRow" display-name="AddNewRow" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
				<body kind="om">
					<![CDATA[rowCount: int4 = TableModel.GetRowCount();
TableModel.AddRow();
if (Source_Archive.P > 0 || Source_Archive.T > 0 || Source_Archive.K > 0 || Source_Archive.NS_time > 0) {
	TableModel.SetCellData(rowCount, 0, Source_Archive.Arch_date);
	TableModel.SetCellData(rowCount, 1, unit.Theme.Pretify(Source_Archive.V_work));
	TableModel.SetCellData(rowCount, 2, unit.Theme.Pretify(Source_Archive.V_work_vost));
	TableModel.SetCellData(rowCount, 3, unit.Theme.Pretify(Source_Archive.V_work_sum));
	TableModel.SetCellData(rowCount, 4, unit.Theme.Pretify(Source_Archive.V_st));
	TableModel.SetCellData(rowCount, 5, unit.Theme.Pretify(Source_Archive.V_st_vost));
	TableModel.SetCellData(rowCount, 6, unit.Theme.Pretify(Source_Archive.V_st_sum));
	TableModel.SetCellData(rowCount, 7, String.ToString("%.2f", Source_Archive.P));
	TableModel.SetCellData(rowCount, 8, String.ToString("%.2f", Source_Archive.T));
	TableModel.SetCellData(rowCount, 9, String.ToString("%.4f", Source_Archive.K));
	TableModel.SetCellData(rowCount, 10, String.ToString("%.2f", Source_Archive.M));
	TableModel.SetCellData(rowCount, 11, String.ToString("%.2f", Source_Archive.M_vost));
	TableModel.SetCellData(rowCount, 12, Source_Archive.NS);
	TableModel.SetCellData(rowCount, 13, String.ToString(Source_Archive.NS_time));
	TableModel.SetCellData(rowCount, 14, rowCount%2);		
	
} else {
	TableModel.SetCellData(rowCount, 0, Source_Archive.Arch_date);
	TableModel.SetCellData(rowCount, 1, "н.д.");
	TableModel.SetCellData(rowCount, 2, "н.д.");
	TableModel.SetCellData(rowCount, 3, "н.д.");
	TableModel.SetCellData(rowCount, 4, "н.д.");
	TableModel.SetCellData(rowCount, 5, "н.д.");
	TableModel.SetCellData(rowCount, 6, "н.д.");
	TableModel.SetCellData(rowCount, 7, "н.д.");
	TableModel.SetCellData(rowCount, 8, "н.д.");
	TableModel.SetCellData(rowCount, 9, "н.д.");
	TableModel.SetCellData(rowCount, 10, "н.д.");
	TableModel.SetCellData(rowCount, 11, "н.д.");
	TableModel.SetCellData(rowCount, 12, "н.д.");
	TableModel.SetCellData(rowCount, 13, "н.д.");
	TableModel.SetCellData(rowCount, 14, rowCount%2);	
}]]>
				</body>
			</do>
