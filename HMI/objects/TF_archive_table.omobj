			<object access-modifier="private" name="Initializer" display-name="Initializer" uuid="e68d3a61-fa95-47e0-b959-e77183886b5a" base-type="Initializer" base-type-id="6db89679-9299-4993-ad1a-0d086cd1c7d2" ver="5" description="" cardinal="1">
				<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Initialized">
					<body kind="om">
						<![CDATA[
parent.TableModel.AddColumn(Column_Arch_date.Id, Column_Arch_date.Title, Column_Arch_date.Description, "", "string", false, true);
parent.TableModel.AddColumn(Column_V_work.Id, Column_V_work.Title, Column_V_work.Description, "м³", "string", false, true);
parent.TableModel.AddColumn(Column_V_work_vost.Id, Column_V_work_vost.Title, Column_V_work_vost.Description, "м³", "string", false, true);
parent.TableModel.AddColumn(Column_V_work_sum.Id, Column_V_work_sum.Title, Column_V_work_sum.Description, "м³", "string", false, true);
parent.TableModel.AddColumn(Column_V_st.Id, Column_V_st.Title, Column_V_st.Description, "м³", "string", false, true);
parent.TableModel.AddColumn(Column_V_st_vost.Id, Column_V_st_vost.Title, Column_V_st_vost.Description, "м³", "string", false, true);
parent.TableModel.AddColumn(Column_V_st_sum.Id, Column_V_st_sum.Title, Column_V_st_sum.Description, "м³", "string", false, true);
parent.TableModel.AddColumn(Column_P.Id, Column_P.Title, Column_P.Description, "МПа", "string", false, true);
parent.TableModel.AddColumn(Column_T.Id, Column_T.Title, Column_T.Description, "°C", "string", false, true);
parent.TableModel.AddColumn(Column_K.Id, Column_K.Title, Column_K.Description, "", "string", false, true);
parent.TableModel.AddColumn(Column_M.Id, Column_M.Title, Column_M.Description, "кг", "string", false, true);
parent.TableModel.AddColumn(Column_M_vost.Id, Column_M_vost.Title, Column_M_vost.Description, "кг", "string", false, true);
parent.TableModel.AddColumn(Column_NS.Id, Column_NS.Title, Column_NS.Description, "", "string", false, true);
parent.TableModel.AddColumn(Column_NS_time.Id, Column_NS_time.Title, Column_NS_time.Description, "сек", "string", false, true);
parent.TableModel.AddColumn(Column_Decor.Id, Column_Decor.Title, Column_Decor.Description, "", "uint2", false, true);
TableDecorator_1.JsonDecorator = TableDecorator_1.JsonDecorator;]]>
					</body>
				</do-on>
			</object>
			<do access-modifier="private" name="SetFinalRow" display-name="SetFinalRow" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
				<body kind="om">
					<![CDATA[
rowCount: int4 = TableModel.GetRowCount();
correctRowCount: int4 = rowCount;
row: int4 = 0; // индекс строки, с которой мы сейчас работаем
// для подведения итогов с одними данными необходимо провести сложение, из других вынести среднее арифметическое, а из третьих вынести последнюю строку. далее объявлены данные столбцов,а  справа - действия над ними
Final_V_work: uint4 = 0; // складываем
Final_V_work_vost: uint4 = 0; // складываем
Final_V_work_sum: uint4 = 0; // пишем наибольшее
Final_V_st: uint4 = 0; // складываем
Final_V_st_vost: uint4 = 0; // складываем
Final_V_st_sum: uint4 = 0; // пишем наибольшее
Final_P: float = 0; // вычисляем среднее
Final_T: float = 0; // вычисляем среднее
Final_K: float = 0; // вычисляем среднее
Final_M: float = 0; // складываем
Final_Mv: float = 0; // складываем
Final_Kod_NS: string = "-"; // заносим объявленную переменную
Final_Time_NS: uint4 = 0; // складываем
// теперь проходим по всем строкам таблицы и заносим данные относительно инструкций выше
while (row < rowCount) {
if (!String.Equals(Variant.ToString(TableModel.GetCellData(row, 1), ""), "н.д.")){
// здесь все даныне в строках складываются между собой
	Final_V_work        = TypeConvert.ToUint4(Final_V_work      + unit.Theme.UnPretify(Variant.ToString(TableModel.GetCellData(row, 1), "")));
	Final_V_work_vost   = TypeConvert.ToUint4(Final_V_work_vost + unit.Theme.UnPretify(Variant.ToString(TableModel.GetCellData(row, 2), "")));
	Final_V_work_sum		= Math.Max(											  unit.Theme.UnPretify(Variant.ToString(TableModel.GetCellData(row, 3), "")), Final_V_work_sum);
	Final_V_st          = TypeConvert.ToUint4(Final_V_st        + unit.Theme.UnPretify(Variant.ToString(TableModel.GetCellData(row, 4), "")));
	Final_V_st_vost     = TypeConvert.ToUint4(Final_V_st_vost   + unit.Theme.UnPretify(Variant.ToString(TableModel.GetCellData(row, 5), "")));
	Final_V_st_sum			= Math.Max(											  unit.Theme.UnPretify(Variant.ToString(TableModel.GetCellData(row, 6), "")), Final_V_st_sum);
	Final_P             = TypeConvert.ToFloat(Final_P           + String.ToFloat(			Variant.ToString(TableModel.GetCellData(row, 7), ""),0));
	Final_T             = TypeConvert.ToFloat(Final_T           + String.ToFloat(			Variant.ToString(TableModel.GetCellData(row, 8), ""),0));
	Final_K             = TypeConvert.ToFloat(Final_K           + String.ToFloat(			Variant.ToString(TableModel.GetCellData(row, 9), ""),0));
	Final_M             = TypeConvert.ToFloat(Final_M           + String.ToFloat(			Variant.ToString(TableModel.GetCellData(row, 10), ""),0));
	Final_Mv            = TypeConvert.ToFloat(Final_Mv          + String.ToFloat(			Variant.ToString(TableModel.GetCellData(row, 11), ""),0));
	Final_Time_NS       = TypeConvert.ToUint4(Final_Time_NS     + String.ToUint4(			Variant.ToString(TableModel.GetCellData(row, 13), ""),0));
	
} else {
	correctRowCount = correctRowCount - 1;
}
	row = row +1;
	
}
// здесь мы делим определенные параметры на кол-во строк для вычисления среднего
Final_P = Final_P / correctRowCount;
Final_T = Final_T / correctRowCount;
Final_K = Final_K / correctRowCount;


// добавляем новую строку на таблицу для записи итогов и записываем все переменные
TableModel.AddRow();
TableModel.SetCellData(rowCount, 0, "ИТОГО: ");
TableModel.SetCellData(rowCount, 1, unit.Theme.Pretify(Final_V_work));
TableModel.SetCellData(rowCount, 2, unit.Theme.Pretify(Final_V_work_vost));
TableModel.SetCellData(rowCount, 3, unit.Theme.Pretify(Final_V_work_sum));
TableModel.SetCellData(rowCount, 4, unit.Theme.Pretify(Final_V_st));
TableModel.SetCellData(rowCount, 5, unit.Theme.Pretify(Final_V_st_vost));
TableModel.SetCellData(rowCount, 6, unit.Theme.Pretify(Final_V_st_sum));

TableModel.SetCellData(rowCount, 7, String.ToString("%.2f", Final_P));
TableModel.SetCellData(rowCount, 8, String.ToString("%.2f", Final_T));
TableModel.SetCellData(rowCount, 9, String.ToString("%.4f", Final_K));
TableModel.SetCellData(rowCount, 10, String.ToString("%.2f", Final_M));
TableModel.SetCellData(rowCount, 11, String.ToString("%.2f", Final_Mv));
TableModel.SetCellData(rowCount, 12, Final_Kod_NS);
TableModel.SetCellData(rowCount, 13, String.ToString(Final_Time_NS));
TableModel.SetCellData(rowCount, 14, 3);

]]>
				</body>
			</do>
			<object access-modifier="private" name="TableDecorator_1" display-name="TableDecorator_1" uuid="4d51542a-a2f7-4295-999b-bbfba525db7c" base-type="TableDecorator" base-type-id="2ff6a2d7-9573-4060-bfea-29c63d61b079" ver="5" description="" cardinal="1">
