			<object access-modifier="private" name="Final" display-name="Final" uuid="a6b721c2-1247-44d6-b728-7dce4e24b68a" base-type="Folder" base-type-id="6b532336-2e8c-41e5-a6b7-2d505e6d5e0b" ver="5" description="" cardinal="1">
				<object access-modifier="private" name="V_work" display-name="V_work" uuid="2bdc3b78-8f45-4c9b-9a00-1fa8563c99da" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5" description="" cardinal="1"/>
				<object access-modifier="private" name="V_work_vost" display-name="V_work_vost" uuid="2c952b22-e8f4-48b8-a559-576533daecf9" base-type="uint4" base-type-id="a42274b8-724b-4f03-bcf9-dd8498c29f8e" ver="5" description="" cardinal="1"/>
