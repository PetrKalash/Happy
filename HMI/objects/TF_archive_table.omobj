	<object access-modifier="private" name="Success" display-name="Success" uuid="f5ba688c-898d-432c-b483-c9e064ba7d4c" base-type="ApItemBool" base-type-id="e3f11724-0f76-4497-8d01-38fbb82fb844" ver="5" description="" cardinal="1">
