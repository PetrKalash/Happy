" + Body.TitleBody.Info_text);
Body.Archive_table_for_print.SetPageFooterText(Body.Ras_text.Text + " Плотность: " + Body.NSI_Table.Density.ValueAsString + " кг/м³ | N2: " + Body.NSI_Table.N2.ValueAsString + " мол.% | CO2: " + Body.NSI_Table.CO2.ValueAsString + " мол.%");
Body.Archive_table_for_print.PrintDialog();]]>
					</body>
