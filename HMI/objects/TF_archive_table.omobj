				<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="OnTimer">
					<body kind="om">
						<![CDATA[if (Ras_day.Quality == 192 && Ras_hour.Quality == 192 && Archive_type_SP.Quality == 192){
	if (Archive_type_SP == 1){
		parent.Text = "Почасовой архив. Расчетный час: " + String.ToString(Ras_hour) + "; Расчетный день: " + String.ToString(Ras_day); 
	}	else {
		parent.Text = "Посуточный архив. Расчетный час: " + String.ToString(Ras_hour) + "; Расчетный день: " + String.ToString(Ras_day); 
	}
} else {
		parent.Text = "Расчетный час: Ошибка опроса! Расчетный день: Ошибка опроса!"; 
}]]>
					</body>
				</do-on>
