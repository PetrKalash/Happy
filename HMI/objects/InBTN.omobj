	<init target="WindowName" ver="5" value="Подтверждение команды"/>
	<init target="WindowName_1" ver="5" value="Внимание"/>
	<init target="Alarm_message" ver="5" value="Действие запрещено по неопределенным причинам"/>
	<do-trace access-modifier="private" target="Alarm_message" ver="5">
		<conditional-expr>
			<condition>
				<![CDATA[!unit.Source.Connection]]>
			</condition>
			<expr>
				<![CDATA["Действие недоступно по причине отсутствия связи с контроллерами"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[DopException]]>
			</condition>
			<expr>
				<![CDATA[DopExceptionText]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[!unit.Security.Access_Operator.Value && !unit.Security.Access_Engineer.Value && EnableAuth]]>
			</condition>
			<expr>
				<![CDATA["Данное действие недоступно для неавторизованного пользователя"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[!(unit.ModeWork.Access || (unit.ModeWork.IsPU && unit.ModeWork.ModeWork == 4)) && EnableAccess && !EnableAuto]]>
			</condition>
			<expr>
				<![CDATA["Действие недоступно в текущем режиме работы"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[!unit.Security.Access_Engineer.Value && EnableEngineer]]>
			</condition>
			<expr>
				<![CDATA["Данное действие доступно только пользователям с правами Инженера и выше"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[(!unit.Security.Access_Operator.Value || !unit.Security.Access_Engineer.Value) && EnableAdmin]]>
			</condition>
			<expr>
				<![CDATA["Данное действие доступно только пользователям с правами администратора"]]>
			</expr>
		</conditional-expr>
		<conditional-expr>
			<condition>
				<![CDATA[!(unit.ModeWork.Access || (unit.ModeWork.IsPU && unit.ModeWork.ModeWork == 4) || unit.ModeWork.ModeWork == 6) && !EnableAccess && EnableAuto]]>
			</condition>
			<expr>
				<![CDATA["Действие недоступно в текущем режиме работы"]]>
			</expr>
		</conditional-expr>
		<default-expr>
			<expr>
				<![CDATA[""]]>
			</expr>
		</default-expr>
	</do-trace>
