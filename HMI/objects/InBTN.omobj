	<object access-modifier="private" name="AlarmMessage" display-name="AlarmMessage" uuid="810c7ed5-2098-4be4-97a2-8efc87d53271" base-type="Action" base-type-id="a9ee9770-1c4a-44c9-b815-157d9fc2ab95" ver="5" description="" cardinal="1">
		<designed target="Enabled" value="true" ver="5"/>
		<designed target="InvokeTrigger" value="false" ver="5"/>
		<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Invoked" form-action="open-dialog" form-by-id="false">
			<object access-modifier="private" uuid="bbea467c-1434-4437-b354-31393ab2614a" base-type="MessageDialog_1" base-type-id="e57be645-5922-4aa1-be96-4629255ec5dc" ver="5">
				<init target="Message" ver="5" ref="here.Alarm_message"/>
				<init target="Icon" ver="5" value="2"/>
				<designed target="Scale" value="1.5" ver="5"/>
				<designed target="WindowBorderStyle" value="0" ver="5"/>
				<do-trace access-modifier="private" target="BrushColor" ver="5">
					<body kind="om">
						<![CDATA[pTheme.BackgroundColor]]>
					</body>
				</do-trace>
				<designed target="PenWidth" value="-1" ver="5"/>
				<designed target="PenStyle" value="0" ver="5"/>
			</object>
		</do-on>
	</object>
	<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="MouseClick">
		<body kind="om">
			<![CDATA[DebugTool_1.Log(Alarm_message.Value);

if( String.Length(Alarm_message) != 0 || (DopException && String.Length(DopExceptionText) != 0) )
{
	AlarmMessage.Invoke();
}
else
{
	if (!DopAction.Enabled){
		here.AcceptDialog.Invoke();
	} else {
		DopAction.Invoke();
	}	
}]]>
		</body>
	</do-on>
