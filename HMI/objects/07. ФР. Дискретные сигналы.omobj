		<object access-modifier="private" name="DITable" display-name="DITable" uuid="682f63bc-b478-4205-ab7d-66bf3651aad1" base-type="AITable_1" base-type-id="ae7355d6-ed4d-4eb0-940b-7e1b6c836fd0" ver="5" description="" cardinal="2">
