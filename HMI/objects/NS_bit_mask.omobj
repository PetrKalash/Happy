			<do access-modifier="private" name="SetNSRow" display-name="SetNSRow" ver="5" type="void" type-id="cfbbcafa-e13e-4354-a33a-6e57b818e4da">
				<body kind="om">
					<![CDATA[rowCount: int4 = TableModel.GetRowCount();
TableModel.AddRow();
TableModel.SetCellData(rowCount, 0, bit);
TableModel.SetCellData(rowCount, 1, desc);
TableModel.SetCellData(rowCount, 2, note);
TableModel.SetCellData(rowCount, 3, rowCount%2);
]]>
				</body>
				<param access-modifier="private" name="bit" display-name="" uuid="3688ddae-2a11-445f-90ae-01409c2b8ec3" base-type="string" base-type-id="76403785-f3d5-41a7-9eb6-d19d2aa2d95d" ver="5"/>
