			</do>
			<object access-modifier="private" name="Initializer_1" display-name="Initializer_1" uuid="38938e15-3f40-4c70-a8cb-b45893215c4a" base-type="Initializer" base-type-id="6db89679-9299-4993-ad1a-0d086cd1c7d2" ver="5" description="" cardinal="1">
				<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Initialized">
					<body kind="om">
						<![CDATA[
parent.TableModel.AddColumn(Column_bit.Id, Column_bit.Title, Column_bit.Description, "", "string", false, true);
parent.TableModel.AddColumn(Column_desc.Id, Column_desc.Title, Column_desc.Description, "", "string", false, true);
parent.TableModel.AddColumn(Column_note.Id, Column_note.Title, Column_note.Description, "", "string", false, true);
parent.TableModel.AddColumn(Column_decor.Id, Column_decor.Title, Column_decor.Description, "", "uint2", false, true);


SetNSRow("0х00000001", "НС от ПП: Т > Tmax" , "установка обоих флагов - неисправность датчика");
SetNSRow("0х00000002", "НС от ПП: T < Tmin", "");
SetNSRow("0х00000004", "НС от ПП: P > Pmax" , "установка обоих флагов - неисправность датчика");
SetNSRow("0х00000008", "НС от ПП: P < Pmin", "");
SetNSRow("0х00000010", "НС от ПП: признак наличия информации в статусах подканалов", "");
SetNSRow("0х00000020", "НС от ПП: имеются отключенные лучи", "");
SetNSRow("0х00000040", "НС от ПП: загрязнение УЗ", "");
SetNSRow("0x00000080", "НС от ПП: нет связи с дублирующим устройством", "");
SetNSRow("0x00000100", "НС от ПП: сбой всех лучей ультразвука - нет ни одного луча", "");
SetNSRow("0x00000200", "НС от ПП: значение плотности выше максимального предела" , "установка обоих флагов - неисправность датчика");
SetNSRow("0x00000400", "НС от ПП: значение плотности ниже максимального предела", "");
SetNSRow("0x00000800", "НС от ПП: отклонение скорости звука одного из лучей от средней", "");
SetNSRow("0х00001000", "НС от ПП: ошибка настроек", "");
SetNSRow("0х00002000", "НС от ПП: сервисный режим", "");
SetNSRow("0х00004000", "НС от ПП: сбой АЦП", "");
SetNSRow("0х00008000", "НС от ПП: сбой памяти FRAM", "");
SetNSRow("0х00010000", "Общий бит НС от ПП", "");
SetNSRow("0х00020000", "Нет питания" , "только в архиве");
SetNSRow("0х00040000", "Нет связи с ПП", "");
SetNSRow("0х00080000", "НС по расходу: Q > Qmax или Qotc <= Q <= Qmin", "");
SetNSRow("0х00100000", "НС по температуре: Т > Tmax или T < Tmin", "");
SetNSRow("0х00200000", "НС по давлению: P > 1.1 * Pmax или P < Pmin", "");
SetNSRow("0х00400000", "НС по скорости звука: Vs > Vs max или Vs < Vs min", "");
SetNSRow("0х00800000", "НС по скорости потока: Vp > Vp max или Vp < Vp min", "");
SetNSRow("0x40000000", "НС по расчету коэффициента сжимаемости", "");
SetNSRow("0х80000000", "Общий бит НС", "");]]>
					</body>
				</do-on>
			</object>
		</object>
