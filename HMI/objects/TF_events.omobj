				<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Invoked">
					<body kind="om">
						<![CDATA[Begin_date_SP.DAY = TypeConvert.ToInt2(DateTime.Day(Begin));
Begin_date_SP.MONTH = TypeConvert.ToInt2(DateTime.Month(Begin));
Begin_date_SP.YEAR = TypeConvert.ToInt2(DateTime.Year(Begin));
Begin_date_SP.HOUR = TypeConvert.ToInt2(DateTime.Hour(Begin));
Begin_date_SP.MINUTE = TypeConvert.ToInt2(DateTime.Minute(Begin));
Begin_date_SP.SECOND = TypeConvert.ToInt2(DateTime.Second(Begin));

End_date_SP.DAY = TypeConvert.ToInt2(DateTime.Day(End));
End_date_SP.MONTH = TypeConvert.ToInt2(DateTime.Month(End));
End_date_SP.YEAR = TypeConvert.ToInt2(DateTime.Year(End));
End_date_SP.HOUR = TypeConvert.ToInt2(DateTime.Hour(End));
End_date_SP.MINUTE = TypeConvert.ToInt2(DateTime.Minute(End));
End_date_SP.SECOND = TypeConvert.ToInt2(DateTime.Second(End));]]>
					</body>
				</do-on>
			</object>
