	<do-on access-modifier="private" name="Handler_1" display-name="Handler_1" ver="5" event="Opened">
		<body kind="om">
			<![CDATA[Body.IntervalEditor.End = DateTime.Now();
Body.IntervalEditor.Begin = DateTime.AddDays(DateTime.Now(), -1);
Body.IntervalEditor.OnChange.Invoke();
Archive_type_SP.In = Archive_type;
if (Archive_type == 1) {
	here.Head.Text_1.Text = "Архив событий";
} else {
	here.Head.Text_1.Text = "Архив вмешательств";
}]]>
		</body>
	</do-on>
