    <ct:type name="MSG_Float" access-level="public" uuid="a431fcd8-7dfd-429d-8674-752af4279649">
      <ct:formula source-code="OldValue == Value" target="Event" />
      <attribute type="unit.System.Attributes.Description" value="Значение уставки изменено на {}" />
      <ct:parameter name="Value" access-level="public" access-scope="global" direction="in" type="float32" uuid="f7845ba0-c76f-4468-bce5-3b71f8b1f43a" />
      <ct:parameter name="Event" access-level="public" access-scope="global" direction="none" type="bool" uuid="646d69b9-b0c0-4b85-bfe1-d5e1b0c8ea85">
        <attribute type="unit.Server.Attributes.Alarm" value="{&quot;Condition&quot;:{&quot;IsEnabled&quot;:&quot;true&quot;,&quot;Subconditions&quot;:[{&quot;AckStrategy&quot;:1,&quot;IsEnabled&quot;:true,&quot;IsGenerateEqualSubcondition&quot;:false,&quot;Message&quot;:&quot; &quot;,&quot;Severity&quot;:&quot;300&quot;,&quot;Type&quot;:&quot;On&quot;},{&quot;AckStrategy&quot;:1,&quot;IsGenerateEqualSubcondition&quot;:false,&quot;Severity&quot;:&quot;1&quot;,&quot;Type&quot;:&quot;Off&quot;}],&quot;Type&quot;:&quot;Discrete&quot;}}" />
      </ct:parameter>
      <ct:parameter name="OldValue" access-level="public" access-scope="global" direction="none" type="float32" uuid="4b55ac60-09c0-405a-b4c1-0919e6ceee33" />
      <ct:handler name="On_Value" source-code="OldValue = Value;" access-level="public" uuid="08df0c1b-f6f2-46bb-a493-e1046d5b1afb">
        <ct:trigger on="Value" cause="update" />
      </ct:handler>
      <ct:parameter name="ModeMsg" access-level="public" access-scope="global" direction="in" type="string" uuid="c4376245-998c-4928-a49f-a3141bfd30a3" />
      <ct:handler name="On_Event" source-code="Event.Messages.Selected.Message = ModeMsg  + String.Replace(Event.Messages.Selected.Message, &quot;{}&quot;, String.ToString(&quot;%.3f&quot;, Value.Value));" access-level="public" uuid="44b4d776-3cf5-4de7-935f-59bfb90e97a9">
        <ct:trigger on="Event" cause="message-prepare" />
      </ct:handler>
    </ct:type>
