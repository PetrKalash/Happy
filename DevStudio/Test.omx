      <ct:handler name="On_Event" source-code="if (OutUnit == 0)&#xA;&#x9;UnitStr = &quot;МПа&quot;;&#xA;else if (OutUnit == 1)&#xA;&#x9;UnitStr = &quot;кгс/см²&quot;;&#xA;else if (OutUnit == 2)&#xA;&#x9;UnitStr = &quot;кПа&quot;;&#xA;else if (OutUnit == 3)&#xA;&#x9;UnitStr = &quot;бар&quot;;&#xA;else if (OutUnit == 4)&#xA;&#x9;UnitStr = &quot;кгс/м²&quot;;&#xA;else if (OutUnit == 5)&#xA;&#x9;UnitStr = &quot;°C&quot;;&#xA;else if (OutUnit == 6)&#xA;&#x9;UnitStr = &quot;%&quot;;&#xA;Event.Messages.Selected.Message = ModeMsg  + String.Replace(Event.Messages.Selected.Message, &quot;{}&quot;, String.ToString(&quot;%.3f&quot;, Value.Value)) + UnitStr;" access-level="public" uuid="c898cc3f-b52d-41b3-8b8c-807cf6506ad5">
