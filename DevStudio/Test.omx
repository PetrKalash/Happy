          <ct:formula source-code="!String.Equals(MotivMsg, &quot;нет&quot;) &amp;&amp; Status == 1" target="MotivTrigger" />
          <ct:formula source-code="!String.Equals(ErrorMsg, &quot;нет&quot;) &amp;&amp; Status == 3" target="ErrorTrigger" />
